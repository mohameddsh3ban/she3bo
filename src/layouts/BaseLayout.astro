---
import '@styles/global.css';
import Footer from '@components/layout/Footer.astro';
import NavFloatingButtons from '@components/nav/NavFloatingButtons.astro';
import { navLinks } from '@data/nav';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title = 'Mohamed Shaban (she3bo) — Senior Full-Stack Developer',
  description = 'Senior full-stack developer from Egypt, currently shipping at m2a-fm GmbH in Germany. Built like a train. Spicy by default.',
  ogImage = '/og-image.png',
  canonicalUrl = Astro.url.href,
} = Astro.props;

const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    {/* SEO Meta */}
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.url).toString()} />
    <meta property="og:site_name" content="Mohamed Shaban (she3bo)" />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.url).toString()} />

    {/* Theme color matches paper */}
    <meta name="theme-color" content="#EDE4CC" />

    {/* Favicon */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Fonts — Bangers (display) + Zen Kaku Gothic New (body) + JetBrains Mono */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Bangers&family=Zen+Kaku+Gothic+New:wght@400;500;700;900&family=JetBrains+Mono:wght@400;500;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bangers&family=Zen+Kaku+Gothic+New:wght@400;500;700;900&family=JetBrains+Mono:wght@400;500;700&display=swap"
    />

    {/* Astro View Transitions — smooth fade per DESIGN.md §18.4 */}
    <ClientRouter />

    {/* Structured data — Person schema for Mohamed Shaban */}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Mohamed Shaban",
      "alternateName": "she3bo",
      "url": "https://she3bo.com",
      "jobTitle": "Senior Full-Stack Developer",
      "description": description,
      "worksFor": {
        "@type": "Organization",
        "name": "m2a-fm GmbH"
      },
      "knowsAbout": [
        "Full-Stack Development",
        "Angular",
        "NestJS",
        "TypeScript",
        "PostgreSQL",
        "Software Architecture"
      ],
      "sameAs": [
        "https://github.com/mohameddsh3ban",
        "https://www.linkedin.com/in/mohamed-shaban-0a3b3921b/",
        "https://instagram.com/sha3bann__"
      ]
    })} />
  </head>
  <body>
    <NavFloatingButtons links={navLinks} activeLink={pathname} transition:persist />
    <slot />
    <Footer transition:persist />
  </body>
</html>

<style is:global>
  ::view-transition-old(root) {
    animation: 250ms ease-out both vt-fade-out;
  }
  ::view-transition-new(root) {
    animation: 300ms ease-out both vt-fade-in;
  }
  @keyframes vt-fade-out {
    from { opacity: 1; }
    to { opacity: 0; }
  }
  @keyframes vt-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation: none !important;
    }
  }
</style>
