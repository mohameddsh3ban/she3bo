---
/**
 * ChapterCover — the locked Manga Chapter Cover header (DESIGN.md §18.2, Variant C).
 * Distilled verbatim from the validated test/header-c.astro winner.
 * Opens every inner page: CH number (red) ── ARC label, then a Bangers title +
 * mono subtitle, with an optional character asset, closed by a 3px ink divider
 * with an 80px shatta accent stripe.
 */
interface Props {
  chapter: string;   // e.g. "CH 03"
  arc: string;       // e.g. "THREE ARCS"
  title: string;     // e.g. "EXPERIENCE"
  subtitle?: string; // e.g. "// the career, told as a manga arc"
  asset?: string;    // e.g. "/she3bo/sheb3o-sprinting.webp" (omit for typographic covers)
  assetAlt?: string;
  /** intrinsic px of the asset file — defaults match the 900×1200 character portraits */
  assetWidth?: number;
  assetHeight?: number;
}

const { chapter, arc, title, subtitle, asset, assetAlt = '', assetWidth = 900, assetHeight = 1200 } = Astro.props;
---

<header class="chapter-cover">
  <div class="chapter-meta">
    <span class="chapter-number">{chapter}</span>
    <span class="chapter-divider-text">──</span>
    <span class="chapter-arc">{arc}</span>
  </div>

  <div class:list={['chapter-body', { 'chapter-body--no-asset': !asset }]}>
    <div class="chapter-text">
      <h1 class="page-title">{title}</h1>
      {subtitle && <p class="page-subtitle">{subtitle}</p>}
    </div>
    {asset && (
      <div class="chapter-asset">
        <img src={asset} alt={assetAlt} loading="eager" fetchpriority="high" decoding="async" width={assetWidth} height={assetHeight} />
      </div>
    )}
  </div>

  <hr class="chapter-divider-line" />
</header>

<style>
  .chapter-cover {
    padding-block: var(--spacing-lg) 0;
  }

  .chapter-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 2.5rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .chapter-number {
    color: var(--color-shatta);
    font-weight: 700;
  }

  .chapter-divider-text,
  .chapter-arc {
    color: var(--color-ink-muted);
  }

  .chapter-body {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: var(--spacing-lg);
    align-items: center;
  }

  .chapter-body--no-asset {
    grid-template-columns: 1fr;
  }

  .chapter-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 13vw, 8rem);
    color: var(--color-ink);
    line-height: 0.9;
    margin: 0;
    letter-spacing: 0.02em;
    overflow-wrap: anywhere;
    max-width: 100%;
  }

  .page-subtitle {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    color: var(--color-ink-muted);
    font-style: italic;
    margin: 0;
  }

  .chapter-asset {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .chapter-asset img {
    max-width: 100%;
    max-height: 460px;
    object-fit: contain;
    display: block;
  }

  .chapter-divider-line {
    height: var(--ink-thick);
    background: var(--color-ink);
    border: none;
    margin-top: var(--spacing-lg);
    position: relative;
  }

  .chapter-divider-line::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 80px;
    height: 100%;
    background: var(--color-shatta);
  }

  @media (max-width: 768px) {
    .chapter-body {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }
    .chapter-asset {
      order: -1;
    }
    .chapter-asset img {
      max-height: 300px;
    }
    .chapter-meta {
      flex-wrap: wrap;
      font-size: 0.75rem;
    }
  }
</style>
