---
/**
 * Breadcrumb — the locked top breadcrumb (DESIGN.md §18.5, Variant C).
 * Distilled from test/breadcrumb-c.astro. The last crumb (no href) renders as the
 * current page in shatta red/bold. First crumb always links home.
 * Inner pages: 2 segments, e.g. [{label:'CH 02', href:'/'}, {label:'ABOUT'}].
 * Case studies: 3 segments, e.g. [{'CH 05','/'}, {'PROJECTS','/projects'}, {'PILOT 100'}].
 */
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;
---

<nav class="breadcrumb" aria-label="Breadcrumb">
  {crumbs.map((c, i) => (
    <Fragment>
      {c.href
        ? <a href={c.href} class="crumb">{c.label}</a>
        : <span class="crumb current" aria-current="page">{c.label}</span>}
      {i < crumbs.length - 1 && <span class="crumb-sep">/</span>}
    </Fragment>
  ))}
</nav>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .crumb {
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.15s var(--ease-ink);
  }

  .crumb:hover {
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-color: var(--color-shatta);
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
  }

  .crumb.current {
    color: var(--color-shatta);
    font-weight: 700;
  }

  .crumb-sep {
    color: var(--color-ink-muted);
    opacity: 0.5;
  }

  @media (max-width: 480px) {
    .breadcrumb {
      font-size: 0.75rem;
      flex-wrap: wrap;
      gap: 0.375rem;
    }
  }
</style>
