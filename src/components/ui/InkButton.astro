---
/**
 * InkButton — A manga-style CTA button.
 * Hard ink borders, paper background, hover lifts.
 *
 * Props:
 *   - href: link target
 *   - variant: 'primary' | 'secondary' | 'ghost'
 *   - size: 'sm' | 'md' | 'lg'
 */
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  ariaLabel?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  ariaLabel,
} = Astro.props;

const isExternal = href.startsWith('http');
const target = isExternal ? '_blank' : undefined;
const rel = isExternal ? 'noopener noreferrer' : undefined;
---

<a
  href={href}
  target={target}
  rel={rel}
  aria-label={ariaLabel}
  class={`ink-btn ink-btn--${variant} ink-btn--${size} ${className}`}
>
  <span class="ink-btn__label"><slot /></span>
</a>

<style>
  .ink-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 44px;
    max-width: 100%;
    font-family: var(--font-display);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
    transition:
      transform 150ms var(--ease-snap),
      box-shadow 150ms var(--ease-snap),
      background-color 200ms var(--ease-ink),
      color 200ms var(--ease-ink);
    will-change: transform;
  }

  /* Sizes */
  .ink-btn--sm {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }

  .ink-btn--md {
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
  }

  .ink-btn--lg {
    padding: 1.25rem 2.5rem;
    font-size: 1.25rem;
  }

  /* PRIMARY: Solid ink with paper text, sharp shadow */
  .ink-btn--primary {
    background-color: var(--color-ink);
    color: var(--color-paper);
    border: var(--ink-thick) solid var(--color-ink);
    box-shadow: 4px 4px 0 0 var(--color-shatta);
  }

  .ink-btn--primary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 0 var(--color-shatta);
    color: var(--color-paper);
  }

  .ink-btn--primary:active {
    transform: translate(2px, 2px);
    box-shadow: 0 0 0 0 var(--color-shatta);
  }

  /* SECONDARY: Outlined, paper bg, ink text */
  .ink-btn--secondary {
    background-color: var(--color-paper);
    color: var(--color-ink);
    border: var(--ink-thick) solid var(--color-ink);
    box-shadow: 4px 4px 0 0 var(--color-ink);
  }

  .ink-btn--secondary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 0 var(--color-ink);
    background-color: var(--color-shatta);
    color: var(--color-paper);
  }

  .ink-btn--secondary:active {
    transform: translate(2px, 2px);
    box-shadow: 0 0 0 0 var(--color-ink);
  }

  /* GHOST: minimal, just text with underline */
  .ink-btn--ghost {
    background-color: transparent;
    color: var(--color-ink);
    border: none;
    padding-left: 0;
    padding-right: 0;
  }

  .ink-btn--ghost::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: var(--ink-medium);
    background-color: var(--color-ink);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 200ms var(--ease-snap);
  }

  .ink-btn--ghost {
    position: relative;
  }

  .ink-btn--ghost:hover {
    color: var(--color-shatta);
  }

  .ink-btn--ghost:hover::after,
  .ink-btn--ghost:active::after {
    background-color: var(--color-shatta);
    transform: scaleX(1);
  }

  .ink-btn--ghost:active {
    color: var(--color-shatta);
  }

  .ink-btn__label {
    display: inline-block;
    overflow-wrap: anywhere;
  }
</style>
