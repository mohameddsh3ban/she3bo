---
import type { Project } from '@/data/projects';

interface Props {
  project: Project;
  class?: string;
  /** Above-the-fold cards (the featured hero) load eagerly; the rest lazy. */
  eager?: boolean;
}

const { project, class: className = '', eager = false } = Astro.props;

const chapterWords = [
  'one', 'two', 'three', 'four', 'five', 'six', 'seven',
  'eight', 'nine', 'ten', 'eleven', 'twelve', 'thirteen',
];
const chapterLabel = `// chapter ${chapterWords[project.id - 1] || project.number}`;

const statusClass = {
  'LIVE': 'status--live',
  'PRIVATE BETA': 'status--private-beta',
  'SHIPPED': 'status--shipped',
  'DEMO': 'status--demo',
  'ARCHIVED': 'status--archived',
  'PILOT': 'status--pilot',
  'OPEN SOURCE': 'status--open-source',
}[project.status];
---

<a href={`/projects/${project.slug}`} class={`thumb ${className}`} aria-label={`Read the ${project.name} case study`}>
  {project.art ? (
    <img
      class="thumb__art"
      src={project.art}
      alt={`${project.name} key art`}
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      width="1600"
      height="894"
    />
  ) : (
    <div class="thumb__sketch" aria-hidden="true">
      <span class="thumb__sketch-icon">{project.icon}</span>
      <span class="thumb__sketch-number">{project.number}</span>
    </div>
  )}
  <div class="thumb__overlay">
    <div class="thumb__top">
      <span class="thumb__number">{project.number}</span>
      <span class={`thumb__status ${statusClass}`}>{project.status}</span>
    </div>
    <div class="thumb__caption">
      <h3 class="thumb__name">{project.name}</h3>
      <p class="thumb__chapter">{chapterLabel}</p>
    </div>
  </div>
</a>

<style>
  .thumb {
    aspect-ratio: 16 / 10;
    background-color: var(--color-paper);
    border: var(--ink-bold) solid var(--color-ink);
    display: block;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      transform 150ms var(--ease-snap),
      box-shadow 150ms var(--ease-snap);
  }

  .thumb:focus-visible {
    outline: var(--ink-medium) solid var(--color-shatta);
    outline-offset: 3px;
  }

  .thumb:hover {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 0 var(--color-shatta);
  }

  /* Key-art panel is the hero of the card. */
  .thumb__art {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 300ms var(--ease-snap);
  }

  .thumb:hover .thumb__art {
    transform: scale(1.03);
  }

  /* No key art yet → sketch panel: halftone paper, oversized icon,
     ghost chapter number. Reads as an unfinished manga page on purpose. */
  .thumb__sketch {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-paper-grain);
    background-image: radial-gradient(var(--color-paper-deep) 1px, transparent 1px);
    background-size: 8px 8px;
    transition: transform 300ms var(--ease-snap);
  }

  .thumb:hover .thumb__sketch {
    transform: scale(1.03);
  }

  /* Emoji glyphs are full-color; near-total grayscale keeps the panel
     inside the three-color constitution and reads as pencil sketch. */
  .thumb__sketch-icon {
    font-size: clamp(4rem, 10vw, 7rem);
    line-height: 1;
    filter: grayscale(0.9) contrast(1.05);
    opacity: 0.85;
  }

  .thumb__sketch-number {
    position: absolute;
    right: 0.5rem;
    bottom: 2.5rem;
    font-family: var(--font-display);
    font-size: clamp(5rem, 14vw, 9rem);
    line-height: 1;
    color: var(--color-paper-deep);
    opacity: 0.55;
    user-select: none;
  }

  /* Readable manga overlay: number/status on top, name/chapter on a link tab below. */
  .thumb__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--spacing-sm);
    z-index: 1;
  }

  .thumb__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .thumb__caption {
    background-color: var(--color-ink);
    color: var(--color-paper);
    padding: 0.5rem 0.7rem;
    margin: calc(var(--spacing-sm) * -1);
    margin-top: 0;
  }

  .thumb__number {
    font-family: var(--font-mono);
    font-size: clamp(1.25rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--color-paper);
    background-color: var(--color-ink);
    padding: 0.1rem 0.45rem;
    line-height: 1;
  }

  .thumb__status {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    line-height: 1;
  }

  .status--live {
    background-color: var(--color-shatta);
    color: var(--color-paper);
  }

  /* Pills sit over photographic art — keep a solid paper backing for legibility. */
  .status--private-beta {
    background-color: var(--color-paper);
    color: var(--color-ink);
    border: 1px dashed var(--color-ink);
  }

  .status--demo {
    background-color: var(--color-paper);
    color: var(--color-ink-faded);
    border: var(--ink-thin) solid var(--color-ink-faded);
  }

  .status--shipped {
    background-color: var(--color-ink);
    color: var(--color-paper);
  }

  .status--archived {
    background-color: var(--color-paper);
    color: var(--color-ink-faded);
    border: var(--ink-thin) solid var(--color-ink-faded);
  }

  .status--pilot {
    background-color: var(--color-paper);
    color: var(--color-shatta);
    border: var(--ink-thin) solid var(--color-shatta);
  }

  .status--open-source {
    background-color: var(--color-paper);
    color: var(--color-ink);
    border: var(--ink-thin) solid var(--color-ink);
  }

  .thumb__name {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3.5vw, 2.4rem);
    line-height: 1;
    text-transform: uppercase;
    color: var(--color-paper);
    margin: 0;
    letter-spacing: 0.02em;
  }

  .thumb__chapter {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-paper);
    opacity: 0.8;
    line-height: 1.4;
    margin: 0.15rem 0 0;
    letter-spacing: 0.06em;
  }

  @media (prefers-reduced-motion: reduce) {
    .thumb {
      transition: none;
    }
    .thumb:hover {
      transform: none;
    }
    .thumb__art,
    .thumb__sketch {
      transition: none;
    }
    .thumb:hover .thumb__art,
    .thumb:hover .thumb__sketch {
      transform: none;
    }
  }
</style>
