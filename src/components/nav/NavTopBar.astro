---
/* VARIANT A: NavTopBar — Top fixed sticky bar with hamburger mobile menu */
interface Props {
  activeLink?: string;
}

const { activeLink = '' } = Astro.props;

const links = [
  { label: 'Experience', href: '#experience' },
  { label: 'About', href: '#about' },
  { label: 'Skills', href: '#skills' },
  { label: 'Projects', href: '#projects' },
  { label: 'Contact', href: '#contact' },
];
---

<nav class="topbar" aria-label="Main navigation (top bar variant)">
  <div class="topbar__inner">
    <a href="/" class="topbar__logo">she3bo</a>

    {/* Desktop links */}
    <ul class="topbar__links" role="list">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'topbar__link',
              'ink-underline',
              { 'topbar__link--active': activeLink === link.href }
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    {/* Mobile hamburger — checkbox hack for no-JS */}
    <input type="checkbox" id="topbar-toggle" class="topbar__checkbox" aria-label="Toggle navigation menu" />
    <label for="topbar-toggle" class="topbar__hamburger" aria-hidden="true">
      <span class="topbar__bar"></span>
      <span class="topbar__bar"></span>
      <span class="topbar__bar"></span>
    </label>

    <div class="topbar__dropdown">
      <ul role="list">
        {links.map(link => (
          <li>
            <a
              href={link.href}
              class:list={[
                'topbar__dropdown-link',
                { 'topbar__link--active': activeLink === link.href }
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</nav>

<style>
  .topbar {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    background-color: var(--color-paper);
    border-bottom: var(--ink-thick) solid var(--color-ink);
    z-index: 50;
    padding: var(--spacing-sm) var(--spacing-md);
  }

  .topbar__inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }

  .topbar__logo {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    color: var(--color-ink);
    text-decoration: none;
    letter-spacing: 0.05em;
    text-transform: lowercase;
  }

  .topbar__logo:hover {
    color: var(--color-shatta);
  }

  /* ─── Desktop links ─────────────────────────────────────── */
  .topbar__links {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: var(--spacing-md);
  }

  @media (min-width: 768px) {
    .topbar__links {
      display: flex;
    }
  }

  .topbar__link {
    font-family: var(--font-display);
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink);
    text-decoration: none;
  }

  .topbar__link--active {
    color: var(--color-shatta);
  }

  .topbar__link--active::after {
    transform: scaleX(1) !important;
    background-color: var(--color-shatta) !important;
  }

  /* ─── Mobile hamburger ──────────────────────────────────── */
  .topbar__checkbox {
    display: none;
  }

  .topbar__hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 4px;
    z-index: 52;
  }

  @media (min-width: 768px) {
    .topbar__hamburger {
      display: none;
    }
  }

  .topbar__bar {
    display: block;
    width: 24px;
    height: var(--ink-thick);
    background-color: var(--color-ink);
    transition: transform 200ms var(--ease-snap), opacity 200ms var(--ease-ink);
  }

  .topbar__checkbox:checked ~ .topbar__hamburger .topbar__bar:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }

  .topbar__checkbox:checked ~ .topbar__hamburger .topbar__bar:nth-child(2) {
    opacity: 0;
  }

  .topbar__checkbox:checked ~ .topbar__hamburger .topbar__bar:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* ─── Mobile dropdown ───────────────────────────────────── */
  .topbar__dropdown {
    position: absolute;
    top: 100%;
    left: calc(-1 * var(--spacing-md));
    right: calc(-1 * var(--spacing-md));
    background-color: var(--color-paper);
    border-bottom: var(--ink-thick) solid var(--color-ink);
    padding: var(--spacing-sm) var(--spacing-md);
    max-height: 0;
    overflow: hidden;
    transition: max-height 300ms var(--ease-ink), padding 300ms var(--ease-ink);
    padding-top: 0;
    padding-bottom: 0;
    z-index: 51;
  }

  .topbar__dropdown ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .topbar__checkbox:checked ~ .topbar__dropdown {
    max-height: 400px;
    padding: var(--spacing-sm) var(--spacing-md);
  }

  @media (min-width: 768px) {
    .topbar__dropdown {
      display: none;
    }
  }

  .topbar__dropdown-link {
    font-family: var(--font-display);
    font-size: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink);
    text-decoration: none;
    display: block;
    padding: var(--spacing-xs) 0;
    border-bottom: var(--ink-thin) solid var(--color-paper-shadow);
  }

  .topbar__dropdown-link:hover {
    color: var(--color-shatta);
  }

  .topbar__dropdown-link.topbar__link--active {
    color: var(--color-shatta);
    border-bottom-color: var(--color-shatta);
  }

  @media (prefers-reduced-motion: reduce) {
    .topbar__bar,
    .topbar__dropdown {
      transition: none;
    }
  }
</style>
