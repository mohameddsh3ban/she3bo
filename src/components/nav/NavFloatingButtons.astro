---
/* VARIANT C: NavFloatingButtons — Floating ink-button pill group, top-right.
   Locked site-wide nav (DESIGN.md §18.4). Rendered once in BaseLayout with
   transition:persist so it never flashes across navigations. */
import { navLinks, type NavLink } from '@data/nav';

interface Props {
  activeLink?: string;
  links?: NavLink[];
}

const {
  activeLink = '',
  links = navLinks,
} = Astro.props;

function isActive(href: string): boolean {
  if (href === '/') return activeLink === '/';
  return activeLink === href || activeLink.startsWith(href + '/');
}
---

{/* Desktop: floating pill group */}
<nav class="floatnav" aria-label="Main navigation">
  <a href="/" class="floatnav__logo" aria-label="she3bo — home">
    <img src="/she3bo-wordmark.svg" alt="she3bo" width="82" height="20" />
  </a>
  {links.map(link => (
    <a
      href={link.href}
      class:list={[
        'floatnav__pill',
        { 'floatnav__pill--active': isActive(link.href) }
      ]}
      aria-current={isActive(link.href) ? 'page' : undefined}
    >
      {link.label}
    </a>
  ))}
</nav>

{/* Mobile: circular toggle + expandable list */}
<div class="floatnav-mobile">
  <input type="checkbox" id="floatnav-toggle" class="floatnav-mobile__checkbox" aria-label="Toggle navigation menu" />
  <label for="floatnav-toggle" class="floatnav-mobile__trigger">
    <img class="floatnav-mobile__icon" src="/she3bo-mark.svg" alt="" width="16" height="30" />
  </label>

  <nav class="floatnav-mobile__panel" aria-label="Main navigation">
    <a
      href="/"
      class:list={[
        'floatnav-mobile__link',
        'floatnav-mobile__link--home',
        { 'floatnav-mobile__link--active': isActive('/') }
      ]}
      aria-current={isActive('/') ? 'page' : undefined}
    >
      ⌂ Home
    </a>
    {links.map(link => (
      <a
        href={link.href}
        class:list={[
          'floatnav-mobile__link',
          { 'floatnav-mobile__link--active': isActive(link.href) }
        ]}
        aria-current={isActive(link.href) ? 'page' : undefined}
      >
        {link.label}
      </a>
    ))}
  </nav>

  {/* tap-anywhere-outside to close — pure CSS, the label toggles the checkbox off */}
  <label for="floatnav-toggle" class="floatnav-mobile__scrim" aria-hidden="true"></label>
</div>

<style>
  /* ─── Desktop: Floating Pill Group ──────────────────────── */
  .floatnav {
    display: none;
    position: fixed;
    top: var(--spacing-md);
    right: var(--spacing-md);
    z-index: 50;
    align-items: center;
    gap: 0;
    background-color: var(--color-paper);
    border: var(--ink-medium) solid var(--color-ink);
    border-radius: 2px;
    overflow: hidden;
    box-shadow: 3px 3px 0 0 var(--color-ink);
  }

  @media (min-width: 768px) {
    .floatnav {
      display: flex;
    }
  }

  .floatnav__logo {
    display: flex;
    align-items: center;
    padding: var(--spacing-xs) var(--spacing-sm);
    border-right: var(--ink-thin) solid var(--color-paper-shadow);
    user-select: none;
  }
  .floatnav__logo img {
    display: block;
    height: 20px;
    width: auto;
  }

  .floatnav__pill {
    font-family: var(--font-display);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink);
    text-decoration: none;
    padding: var(--spacing-xs) var(--spacing-sm);
    border-right: var(--ink-thin) solid var(--color-paper-shadow);
    transition:
      background-color 150ms var(--ease-ink),
      color 150ms var(--ease-ink),
      transform 150ms var(--ease-snap),
      box-shadow 150ms var(--ease-snap);
    position: relative;
  }

  .floatnav__pill:last-child {
    border-right: none;
  }

  .floatnav__pill:hover {
    background-color: var(--color-shatta);
    color: var(--color-paper);
    transform: translate(-2px, -2px);
    box-shadow: 2px 2px 0 0 var(--color-ink);
    z-index: 1;
  }

  .floatnav__pill--active {
    background-color: var(--color-shatta);
    color: var(--color-paper);
  }

  /* ─── Mobile: Circular trigger + panel ──────────────────── */
  .floatnav-mobile {
    display: block;
    position: fixed;
    top: var(--spacing-md);
    right: var(--spacing-md);
    z-index: 50;
  }

  @media (min-width: 768px) {
    .floatnav-mobile {
      display: none;
    }
  }

  /* Transparent native checkbox overlaying the trigger: keyboard-focusable,
     screen-reader-announced, and tappable — fixes the display:none a11y trap. */
  .floatnav-mobile__checkbox {
    position: absolute;
    top: 0;
    right: 0;
    width: 48px;
    height: 48px;
    margin: 0;
    opacity: 0;
    cursor: pointer;
    z-index: 53;
  }

  .floatnav-mobile__trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: var(--color-paper);
    border: var(--ink-thick) solid var(--color-ink);
    box-shadow: 3px 3px 0 0 var(--color-shatta);
    cursor: pointer;
    position: relative;
    z-index: 52;
    transition: transform 150ms var(--ease-snap), box-shadow 150ms var(--ease-snap);
  }

  .floatnav-mobile__trigger:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 0 var(--color-shatta);
  }
  .floatnav-mobile__trigger:active {
    transform: translate(1px, 1px);
    box-shadow: 2px 2px 0 0 var(--color-shatta);
  }
  /* keyboard focus ring on the transparent checkbox shows on the visible trigger */
  .floatnav-mobile__checkbox:focus-visible ~ .floatnav-mobile__trigger {
    outline: var(--ink-thick) solid var(--color-shatta);
    outline-offset: 3px;
  }

  /* full-viewport tap-to-close scrim, only present when the menu is open */
  .floatnav-mobile__scrim {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 49;
    cursor: default;
  }
  .floatnav-mobile__checkbox:checked ~ .floatnav-mobile__scrim {
    display: block;
  }

  .floatnav-mobile__icon {
    display: block;
    height: 30px;
    width: auto;
  }

  .floatnav-mobile__panel {
    position: absolute;
    top: calc(100% + var(--spacing-xs));
    right: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    background-color: var(--color-paper);
    border: var(--ink-medium) solid var(--color-ink);
    border-radius: 2px;
    padding: var(--spacing-xs);
    box-shadow: 4px 4px 0 0 var(--color-ink);
    opacity: 0;
    transform: translateY(-8px) scale(0.95);
    pointer-events: none;
    transition: opacity 200ms var(--ease-ink), transform 200ms var(--ease-snap);
    z-index: 51;
    min-width: 160px;
  }

  .floatnav-mobile__checkbox:checked ~ .floatnav-mobile__panel {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .floatnav-mobile__checkbox:checked ~ .floatnav-mobile__trigger {
    background-color: var(--color-shatta);
    border-color: var(--color-ink);
  }

  .floatnav-mobile__link {
    display: flex;
    align-items: center;
    min-height: 46px;
    font-family: var(--font-display);
    font-size: 1.05rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink);
    text-decoration: none;
    padding: var(--spacing-xs) var(--spacing-sm);
    border: var(--ink-thin) solid transparent;
    -webkit-tap-highlight-color: transparent;
    transition: background-color 150ms var(--ease-ink), color 150ms var(--ease-ink);
  }

  .floatnav-mobile__link:hover,
  .floatnav-mobile__link:active {
    background-color: var(--color-paper-shadow);
    color: var(--color-shatta);
  }

  .floatnav-mobile__link--active {
    background-color: var(--color-shatta);
    color: var(--color-paper);
  }

  /* Home sits at the top as the base, separated from the chapter links */
  .floatnav-mobile__link--home {
    margin-bottom: var(--spacing-xs);
    border-bottom: var(--ink-thin) solid var(--color-paper-shadow);
  }

  @media (prefers-reduced-motion: reduce) {
    .floatnav__pill,
    .floatnav-mobile__trigger,
    .floatnav-mobile__panel,
    .floatnav-mobile__link {
      transition: none;
    }
  }
</style>

<script>
  // The nav is transition:persist (DOM reused across client-side View Transitions),
  // so re-sync the active pill + close the mobile panel after each navigation.
  // No-JS users get correct active state from the full server render every load.
  function syncActiveNav() {
    const path = window.location.pathname;
    const isActive = (href: string) =>
      href === '/' ? path === '/' : path === href || path.startsWith(href + '/');

    document.querySelectorAll<HTMLAnchorElement>('.floatnav__pill').forEach((el) => {
      const a = isActive(el.getAttribute('href') || '');
      el.classList.toggle('floatnav__pill--active', a);
      if (a) el.setAttribute('aria-current', 'page'); else el.removeAttribute('aria-current');
    });
    document.querySelectorAll<HTMLAnchorElement>('.floatnav-mobile__link').forEach((el) => {
      const a = isActive(el.getAttribute('href') || '');
      el.classList.toggle('floatnav-mobile__link--active', a);
      if (a) el.setAttribute('aria-current', 'page'); else el.removeAttribute('aria-current');
    });
    const cb = document.getElementById('floatnav-toggle') as HTMLInputElement | null;
    if (cb) cb.checked = false;
  }
  document.addEventListener('astro:after-swap', syncActiveNav);
</script>
