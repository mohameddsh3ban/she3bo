---
---

<footer class="footer">
  <div class="footer__divider" aria-hidden="true"></div>
  <div class="footer__container">
    <p class="footer__copy">&copy; 2026 Mohamed Shaban (she3bo). Built with Astro, ink ,and Spicy Taste.</p>
    <a
      href="https://github.com/mohameddsh3ban/sheb3o-v2"
      target="_blank"
      rel="noopener noreferrer"
      class="footer__source"
    >view source ↗</a>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-paper-shadow);
    padding: var(--spacing-md) var(--spacing-lg);
  }

  .footer__divider {
    max-width: 1400px;
    margin: 0 auto var(--spacing-md);
    border-top: var(--ink-thin) solid var(--color-ink);
  }

  .footer__container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }

  .footer__copy {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-ink-muted);
    margin: 0;
  }

  .footer__source {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--color-ink-muted);
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
    transition: color 150ms var(--ease-ink);
  }

  .footer__source:hover,
  .footer__source:active {
    color: var(--color-shatta);
  }

  @media (max-width: 767px) {
    .footer {
      padding: var(--spacing-md) var(--spacing-sm);
    }

    .footer__container {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--spacing-xs);
    }
  }
</style>
