---
import { projects } from '@/data/projects';
import SectionHeader from '@components/ui/SectionHeader.astro';
import PaperPanel from '@components/ui/PaperPanel.astro';
import InkButton from '@components/ui/InkButton.astro';
import ProjectThumbnail from '@components/projects/ProjectThumbnail.astro';
---

<PaperPanel tag="section" id="projects-strip" class="projects-strip">
  <SectionHeader title="PROJECTS" subtitle="// six chapters, six different fights" />

  <div class="projects-strip__stack">
    {projects.map((project, i) => (
      <article class={`projects-strip__panel ${i % 2 === 1 ? 'projects-strip__panel--alt' : ''}`}>
        <div class="projects-strip__thumb-col">
          <ProjectThumbnail project={project} />
        </div>
        <div class="projects-strip__content">
          <div class="projects-strip__head">
            <h3 class="projects-strip__name">{project.name}</h3>
            <span class={`projects-strip__status projects-strip__status--${project.status.toLowerCase().replace('-', '')}`}>
              {project.status}
            </span>
          </div>
          <p class="projects-strip__desc">{project.description}</p>
          <div class="projects-strip__tags">
            {project.tech.map((t) => (
              <span class="projects-strip__tag">{t}</span>
            ))}
          </div>
          <div class="projects-strip__links">
            {project.links.live && (
              <InkButton href={project.links.live} variant="primary" size="sm">Live</InkButton>
            )}
            {project.links.repo && (
              <InkButton href={project.links.repo} variant="secondary" size="sm">Repo</InkButton>
            )}
            {project.links.demo && (
              <InkButton href={project.links.demo} variant="ghost" size="sm">Demo</InkButton>
            )}
          </div>
        </div>
      </article>
    ))}
  </div>
</PaperPanel>

<style>
  .projects-strip__stack {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .projects-strip__panel {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-md);
    padding: var(--spacing-md);
    border: var(--ink-medium) solid var(--color-ink);
    background-color: var(--color-paper);
  }

  .projects-strip__panel--alt {
    background-color: var(--color-paper-grain);
  }

  @media (min-width: 768px) {
    .projects-strip__panel {
      grid-template-columns: 1fr 2fr;
    }
  }

  .projects-strip__thumb-col {
    max-width: 100%;
  }

  .projects-strip__content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    justify-content: center;
  }

  .projects-strip__head {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .projects-strip__name {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    line-height: 1.1;
    text-transform: uppercase;
    color: var(--color-ink);
    margin: 0;
  }

  .projects-strip__status {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    line-height: 1;
  }

  .projects-strip__status--live {
    background-color: var(--color-shatta);
    color: var(--color-paper);
  }

  .projects-strip__status--inprogress {
    border: var(--ink-medium) solid var(--color-ink);
    color: var(--color-ink);
  }

  .projects-strip__status--shipped {
    background-color: var(--color-ink);
    color: var(--color-paper);
  }

  .projects-strip__status--archived {
    border: var(--ink-thin) solid var(--color-ink-faded);
    color: var(--color-ink-faded);
  }

  .projects-strip__desc {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 60ch;
  }

  .projects-strip__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .projects-strip__tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-ink-faded);
    border: var(--ink-thin) solid var(--color-ink-faded);
    padding: 0.15rem 0.5rem;
    letter-spacing: 0.04em;
  }

  .projects-strip__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    margin-top: var(--spacing-xs);
  }
</style>
