---
import { projects } from '@/data/projects';
import PaperPanel from '@components/ui/PaperPanel.astro';
import InkButton from '@components/ui/InkButton.astro';
import ProjectThumbnail from '@components/projects/ProjectThumbnail.astro';

const featured = projects.find((p) => p.featured)!;
const rest = projects.filter((p) => !p.featured);
---

<PaperPanel tag="section" id="projects" class="projects-final">
  {/* ─── FEATURED: PILOT 100 (splash page treatment) ──────────── */}
  <article class="pf__hero">
    <span class="pf__hero-ribbon">FEATURED — VOLUME I</span>
    <div class="pf__hero-thumb">
      <ProjectThumbnail project={featured} eager />
    </div>
    <div class="pf__hero-content">
      <div class="pf__hero-head">
        <h3 class="pf__hero-name">{featured.name}</h3>
        <span class="pf__hero-status">{featured.status}</span>
      </div>
      <span class="pf__hero-callout">USED IN REAL FLIGHT SCHOOLS</span>
      <p class="pf__hero-tagline">{featured.tagline}</p>
      <p class="pf__hero-desc">{featured.description}</p>
      <div class="pf__hero-tags">
        {featured.tech.map((t) => (
          <span class="pf__tag">{t}</span>
        ))}
      </div>
      <div class="pf__hero-links">
        {featured.links.live && (
          <InkButton href={featured.links.live} variant="primary" size="md">Live Site ↗</InkButton>
        )}
        {featured.links.repo && (
          <InkButton href={featured.links.repo} variant="secondary" size="md">Source</InkButton>
        )}
        {featured.links.demo && (
          <InkButton href={featured.links.demo} variant="ghost" size="md">Demo</InkButton>
        )}
      </div>
      <a href={`/projects/${featured.slug}`} class="pf__hero-casestudy">→ Read the full case study</a>
    </div>
  </article>

  {/* ─── REST: COMIC STRIP (Variant B panels) ─────────────────── */}
  <div class="pf__strip">
    {rest.map((project, i) => (
      <article class={`pf__panel ${i % 2 === 1 ? 'pf__panel--alt' : ''}`}>
        <div class="pf__panel-thumb">
          <ProjectThumbnail project={project} />
        </div>
        <div class="pf__panel-content">
          <div class="pf__panel-head">
            <h3 class="pf__panel-name">{project.name}</h3>
            <span class={`pf__panel-status pf__panel-status--${project.status.toLowerCase().replace(/[\s-]/g, '')}`}>
              {project.status}
            </span>
          </div>
          <p class="pf__panel-tagline">{project.tagline}</p>
          <p class="pf__panel-desc">{project.description}</p>
          <div class="pf__panel-tags">
            {project.tech.map((t) => (
              <span class="pf__tag">{t}</span>
            ))}
          </div>
          <div class="pf__panel-links">
            {project.links.live && (
              <InkButton href={project.links.live} variant="primary" size="sm">Live ↗</InkButton>
            )}
            {project.links.repo && (
              <InkButton href={project.links.repo} variant="secondary" size="sm">Repo</InkButton>
            )}
            {project.links.demo && (
              <InkButton href={project.links.demo} variant="ghost" size="sm">Demo</InkButton>
            )}
          </div>
          <a href={`/projects/${project.slug}`} class="pf__panel-casestudy">→ Read the case study</a>
        </div>
      </article>
    ))}
  </div>
</PaperPanel>

<style>
  /* ─── FEATURED HERO ─────────────────────────────────────────── */
  .pf__hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
    padding: calc(var(--spacing-md) * 1.5);
    border: var(--ink-thick) solid var(--color-ink);
    box-shadow: 8px 8px 0 0 var(--color-shatta);
    background-color: var(--color-paper);
    position: relative;
    overflow: visible;
  }

  @media (min-width: 768px) {
    .pf__hero {
      grid-template-columns: 1fr 1fr;
    }

    .pf__hero-thumb {
      min-height: 420px;
    }
  }

  .pf__hero-ribbon {
    position: absolute;
    top: -1px;
    right: var(--spacing-md);
    background-color: var(--color-shatta);
    color: var(--color-paper);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem 0.5rem;
    line-height: 1;
    z-index: 1;
  }

  .pf__hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    justify-content: center;
  }

  .pf__hero-head {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .pf__hero-name {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.1;
    text-transform: uppercase;
    color: var(--color-ink);
    margin: 0;
  }

  .pf__hero-status {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    background-color: var(--color-shatta);
    color: var(--color-paper);
    line-height: 1;
  }

  .pf__hero-tagline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    line-height: 1.5;
    color: var(--color-ink);
    font-weight: 700;
    margin: 0;
  }

  .pf__hero-desc {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 55ch;
  }

  .pf__hero-callout {
    display: inline-block;
    align-self: flex-start;
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background-color: var(--color-shatta);
    color: var(--color-paper);
    padding: 4px 12px;
    transform: rotate(-2deg);
  }

  .pf__hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .pf__hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    margin-top: var(--spacing-xs);
  }

  /* ─── COMIC STRIP PANELS ────────────────────────────────────── */
  .pf__strip {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .pf__panel {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-md);
    padding: var(--spacing-md);
    border: var(--ink-medium) solid var(--color-ink);
    background-color: var(--color-paper);
  }

  .pf__panel--alt {
    background-color: var(--color-paper-grain);
  }

  @media (min-width: 768px) {
    .pf__panel {
      grid-template-columns: 1fr 2fr;
    }
  }

  .pf__panel-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    justify-content: center;
  }

  .pf__panel-head {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .pf__panel-name {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    line-height: 1.1;
    text-transform: uppercase;
    color: var(--color-ink);
    margin: 0;
  }

  .pf__panel-status {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    line-height: 1;
  }

  .pf__panel-status--live {
    background-color: var(--color-shatta);
    color: var(--color-paper);
  }

  .pf__panel-status--privatebeta {
    border: 1px dashed var(--color-ink);
    color: var(--color-ink);
  }

  .pf__panel-status--demo {
    border: var(--ink-thin) solid var(--color-ink-faded);
    color: var(--color-ink-faded);
  }

  .pf__panel-status--shipped {
    background-color: var(--color-ink);
    color: var(--color-paper);
  }

  .pf__panel-status--archived {
    border: var(--ink-thin) solid var(--color-ink-faded);
    color: var(--color-ink-faded);
  }

  .pf__panel-status--pilot {
    border: var(--ink-thin) solid var(--color-shatta);
    color: var(--color-shatta);
  }

  .pf__panel-status--opensource {
    border: var(--ink-thin) solid var(--color-ink);
    color: var(--color-ink);
  }

  .pf__panel-desc {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 60ch;
  }

  /* Mobile shows the punchy tagline; desktop keeps the full description. */
  .pf__panel-tagline {
    display: none;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.5;
    color: var(--color-ink);
    margin: 0;
    max-width: 45ch;
  }

  .pf__panel-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .pf__panel-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    margin-top: var(--spacing-xs);
  }

  /* ─── CASE STUDY LINK ────────────────────────────────────────── */
  .pf__hero-casestudy,
  .pf__panel-casestudy {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-shatta);
    text-decoration: none;
    letter-spacing: 0.04em;
    margin-top: var(--spacing-xs);
    transition: color 150ms var(--ease-ink);
  }

  .pf__panel-casestudy {
    font-size: 0.8rem;
    align-self: flex-start;
  }

  .pf__hero-casestudy:hover,
  .pf__panel-casestudy:hover {
    color: var(--color-shatta-deep);
    text-decoration: underline;
  }

  /* ─── SHARED TAG ────────────────────────────────────────────── */
  .pf__tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-ink-faded);
    border: var(--ink-thin) solid var(--color-ink);
    padding: 0.15rem 0.5rem;
    letter-spacing: 0.04em;
  }

  /* ─── MOBILE (<768px) ───────────────────────────────────────────
     Three nested paddings (page + PaperPanel + card) were squeezing
     thumbnails to ~166px on a 375px screen. De-nest, let the art
     bleed to the card border, and drop overlay text that repeats
     the name/status printed directly below it. */
  @media (max-width: 767px) {
    /* :global + double class outranks PaperPanel's scoped .paper-panel rule. */
    :global(.paper-panel.projects-final) {
      padding: 0; /* default PaperPanel variant draws nothing — its padding is dead space here */
    }

    .pf__hero {
      padding: var(--spacing-sm);
      margin-bottom: var(--spacing-md);
      box-shadow: 5px 5px 0 0 var(--color-shatta);
    }

    .pf__panel {
      padding: var(--spacing-sm);
    }

    .pf__strip {
      gap: var(--spacing-sm);
    }

    /* Key art becomes the full-width card header. */
    .pf__hero-thumb,
    .pf__panel-thumb {
      margin: calc(var(--spacing-sm) * -1);
      margin-bottom: 0;
    }

    /* Name + status already sit right under the art — kill the
       duplicated overlay caption and status pill on small screens. */
    .pf__hero-thumb :global(.thumb__caption),
    .pf__panel-thumb :global(.thumb__caption),
    .pf__hero-thumb :global(.thumb__status),
    .pf__panel-thumb :global(.thumb__status) {
      display: none;
    }

    /* Tagline in, long description out — the case study holds the rest. */
    .pf__panel-tagline {
      display: block;
    }

    .pf__panel-desc {
      display: none;
    }
  }
</style>
