---
import { channels } from '@data/channels';

const bubbleConfig = [
  { id: 'email',     text: 'EMAIL ME ↗',       position: 'top-left',     tail: 'right' as const },
  { id: 'linkedin',  text: 'LINKEDIN?',         position: 'top-right',    tail: 'left' as const },
  { id: 'github',    text: 'SEE MY CODE',       position: 'bottom-left',  tail: 'right' as const },
  { id: 'instagram', text: 'OFF THE KEYBOARD',  position: 'bottom-right', tail: 'left' as const },
];

const bubbles = bubbleConfig.map(b => {
  const ch = channels.find(c => c.id === b.id)!;
  return { ...b, href: ch.href, handle: ch.handle, label: ch.label };
});
---

<section class="sbub" id="contact" aria-label="Contact Mohamed Shaban">
  <div class="sbub__container">
    <header class="sbub__header">
      <h2 class="sbub__title">FIND ME</h2>
      <p class="sbub__subtitle">// pick a panel, drop a line</p>
    </header>

    <div class="sbub__scene">
      {bubbles.map((b) => (
        <a
          href={b.href}
          target={b.href.startsWith('mailto:') ? undefined : '_blank'}
          rel={b.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
          class={`sbub__bubble sbub__bubble--${b.position}`}
          aria-label={`${b.label} — ${b.handle}`}
        >
          <span class="sbub__bubble-inner" data-tail={b.tail}>
            <span class="sbub__bubble-text">{b.text}</span>
          </span>
        </a>
      ))}

      <img
        src="/images/sheb3o/sheb3o-wave.png"
        alt="Sheb3o — Mohamed Shaban waving"
        class="sbub__image"
        width="400"
        height="600"
        loading="lazy"
      />
    </div>

    <p class="sbub__signature">— Mohamed Shaban</p>
  </div>
</section>

<style>
  .sbub {
    padding: var(--spacing-xl) var(--spacing-md) var(--spacing-lg);
  }

  .sbub__container {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
  }

  /* ─── HEADER ───────────────────────────────────────────────── */
  .sbub__header {
    text-align: center;
  }

  .sbub__title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    color: var(--color-ink);
    margin: 0;
    line-height: 1;
    position: relative;
    display: inline-block;
  }

  .sbub__title::after {
    content: '';
    display: block;
    width: 100%;
    height: var(--ink-bold);
    background-color: var(--color-ink);
    margin-top: 0.25rem;
  }

  .sbub__subtitle {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-ink-faded);
    margin: var(--spacing-xs) 0 0;
  }

  /* ─── SCENE (desktop: relative positioning) ────────────────── */
  .sbub__scene {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
    width: 100%;
  }

  .sbub__image {
    display: block;
    max-width: 350px;
    width: 60%;
    height: auto;
    object-fit: contain;
    position: relative;
    z-index: 1;
  }

  /* ─── BUBBLES ──────────────────────────────────────────────── */
  .sbub__bubble {
    text-decoration: none;
    display: block;
    transition:
      transform 150ms var(--ease-snap),
      box-shadow 150ms var(--ease-snap);
  }

  .sbub__bubble:hover {
    transform: translate(-2px, -2px);
  }

  .sbub__bubble-inner {
    display: inline-block;
    background-color: var(--color-paper);
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: clamp(0.85rem, 1.5vw, 1.1rem);
    letter-spacing: 0.05em;
    padding: 0.6rem 1.2rem;
    border: var(--ink-bold) solid var(--color-ink);
    border-radius: 50% 50% 50% 50% / 60% 60% 60% 60%;
    white-space: nowrap;
    box-shadow: 3px 3px 0 0 var(--color-ink);
    transition: box-shadow 150ms var(--ease-snap);
    position: relative;
  }

  .sbub__bubble:hover .sbub__bubble-inner {
    box-shadow: 5px 5px 0 0 var(--color-shatta);
  }

  .sbub__bubble-text {
    display: inline-block;
  }

  /* Bubble tails */
  .sbub__bubble-inner[data-tail="right"]::after,
  .sbub__bubble-inner[data-tail="left"]::after {
    content: '';
    position: absolute;
    bottom: 4px;
    width: 0;
    height: 0;
  }

  .sbub__bubble-inner[data-tail="right"]::after {
    right: -10px;
    border-top: 6px solid transparent;
    border-bottom: 6px solid transparent;
    border-left: 12px solid var(--color-ink);
  }

  .sbub__bubble-inner[data-tail="left"]::after {
    left: -10px;
    border-top: 6px solid transparent;
    border-bottom: 6px solid transparent;
    border-right: 12px solid var(--color-ink);
  }

  .sbub__signature {
    font-family: var(--font-mono);
    font-style: italic;
    font-size: 0.9rem;
    color: var(--color-ink-faded);
    margin: 0;
    text-align: center;
  }

  /* ─── DESKTOP: absolute bubble positioning ─────────────────── */
  @media (min-width: 768px) {
    .sbub__scene {
      min-height: 550px;
      padding: var(--spacing-lg) 0;
    }

    .sbub__image {
      max-width: 380px;
      width: auto;
    }

    .sbub__bubble {
      position: absolute;
      z-index: 2;
    }

    .sbub__bubble--top-left {
      top: 0;
      left: 5%;
    }

    .sbub__bubble--top-right {
      top: 2rem;
      right: 5%;
    }

    .sbub__bubble--bottom-left {
      bottom: 4rem;
      left: 2%;
    }

    .sbub__bubble--bottom-right {
      bottom: 3rem;
      right: 2%;
    }
  }

  @media (min-width: 1024px) {
    .sbub__bubble--top-left {
      left: 0;
    }

    .sbub__bubble--top-right {
      right: 0;
    }

    .sbub__bubble--bottom-left {
      left: -2%;
    }

    .sbub__bubble--bottom-right {
      right: -2%;
    }
  }

  /* ─── MOBILE: stacked layout ───────────────────────────────── */
  @media (max-width: 767px) {
    .sbub {
      padding: var(--spacing-lg) var(--spacing-sm);
    }

    .sbub__scene {
      gap: var(--spacing-sm);
    }

    .sbub__image {
      order: -1;
      max-width: 240px;
      width: 55%;
    }

    .sbub__bubble {
      width: 100%;
      max-width: 20rem;
    }

    .sbub__bubble-inner {
      display: block;
      text-align: center;
      border-radius: 2px;
      width: 100%;
    }

    .sbub__bubble-inner[data-tail="right"]::after,
    .sbub__bubble-inner[data-tail="left"]::after {
      display: none;
    }
  }
</style>
