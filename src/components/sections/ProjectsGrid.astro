---
import { projects } from '@/data/projects';
import SectionHeader from '@components/ui/SectionHeader.astro';
import PaperPanel from '@components/ui/PaperPanel.astro';
import InkButton from '@components/ui/InkButton.astro';
import ProjectThumbnail from '@components/projects/ProjectThumbnail.astro';
---

<PaperPanel tag="section" id="projects-grid" class="projects-grid">
  <SectionHeader title="PROJECTS" subtitle="// six chapters, six different fights" />

  <div class="projects-grid__grid">
    {projects.map((project) => (
      <article class="projects-grid__card">
        <ProjectThumbnail project={project} />
        <div class="projects-grid__info">
          <p class="projects-grid__desc">{project.description}</p>
          <div class="projects-grid__tags">
            {project.tech.map((t) => (
              <span class="projects-grid__tag">{t}</span>
            ))}
          </div>
          <div class="projects-grid__links">
            {project.links.live && (
              <InkButton href={project.links.live} variant="primary" size="sm">Live</InkButton>
            )}
            {project.links.repo && (
              <InkButton href={project.links.repo} variant="secondary" size="sm">Repo</InkButton>
            )}
            {project.links.demo && (
              <InkButton href={project.links.demo} variant="ghost" size="sm">Demo</InkButton>
            )}
          </div>
        </div>
      </article>
    ))}
  </div>
</PaperPanel>

<style>
  .projects-grid__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-md);
  }

  @media (min-width: 768px) {
    .projects-grid__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .projects-grid__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .projects-grid__card {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .projects-grid__info {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .projects-grid__desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0;
  }

  .projects-grid__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .projects-grid__tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-ink-faded);
    border: var(--ink-thin) solid var(--color-ink-faded);
    padding: 0.15rem 0.5rem;
    letter-spacing: 0.04em;
  }

  .projects-grid__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    margin-top: var(--spacing-xs);
  }
</style>
