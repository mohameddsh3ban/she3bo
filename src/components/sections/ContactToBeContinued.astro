---
import SpeechBubble from '@components/ui/SpeechBubble.astro';
import { channels } from '@data/channels';

const emailChannel = channels.find(c => c.primary)!;
const otherChannels = channels.filter(c => !c.primary);
---

<section class="tbc" id="contact" aria-label="Contact Mohamed Shaban">
  <div class="tbc__divider"></div>

  <div class="tbc__container">
    <div class="tbc__content">
      <div class="tbc__body">
        <p>The portfolio ends here.</p>
        <p>The conversation starts wherever you want.</p>
      </div>

      <div class="tbc__channels">
        <a
          href={emailChannel.href}
          class="tbc__btn tbc__btn--primary"
          aria-label={`${emailChannel.label} — ${emailChannel.handle}`}
        >
          <span class="tbc__btn-top">
            <span class="tbc__btn-icon">{emailChannel.icon}</span>
            <span class="tbc__btn-label">{emailChannel.label}</span>
          </span>
          <span class="tbc__btn-handle">{emailChannel.handle}</span>
        </a>

        {otherChannels.map((ch) => (
          <a
            href={ch.href}
            target="_blank"
            rel="noopener noreferrer"
            class="tbc__btn tbc__btn--secondary"
            aria-label={`${ch.label} — ${ch.handle}`}
          >
            <span class="tbc__btn-top">
              <span class="tbc__btn-icon">{ch.icon}</span>
              <span class="tbc__btn-label">{ch.label}</span>
            </span>
            <span class="tbc__btn-handle">{ch.handle}</span>
          </a>
        ))}
      </div>

      <p class="tbc__copy-hint" data-email={emailChannel.handle}>
        <kbd>CTRL</kbd> + <kbd>K</kbd> to copy email
      </p>

      <p class="tbc__signature">— Mohamed Shaban <span class="tbc__signature-nick">(she3bo)</span></p>
    </div>

    <div class="tbc__figure">
      <div class="tbc__panel">
        <div class="tbc__bubble">
          <SpeechBubble text="YO!" tail="down" variant="shout" />
        </div>
        <img
          src="/shata/shatta-yo.webp"
          alt="Shatta saying yo"
          class="tbc__image"
          width="240"
          height="240"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .tbc {
    padding: var(--spacing-section) var(--spacing-md);
  }

  /* ─── TOP DIVIDER (no label) ───────────────────────────────── */
  .tbc__divider {
    max-width: 900px;
    margin: 0 auto var(--spacing-lg);
    border-top: var(--ink-medium, 2px) solid var(--color-ink);
  }

  /* Constrain the whole section to a readable, centered column so it
     no longer sprawls full-bleed with dead whitespace. */
  .tbc__container {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-lg);
    align-items: start;
  }

  @media (min-width: 768px) {
    .tbc__container {
      /* content reads as the spine; Shatta is a slim accent rail,
         not a co-protagonist half of the page. */
      grid-template-columns: minmax(0, 1fr) auto;
      gap: var(--spacing-xl);
      align-items: center;
    }
  }

  /* ─── LEFT: CONTENT ──────────────────────────────────────────── */
  .tbc__content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .tbc__body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .tbc__body p {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 50ch;
  }

  /* ─── CHANNEL GRID (tidy 2x2, contained — not full-bleed) ────── */
  .tbc__channels {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-sm);
    width: 100%;
    max-width: 34rem;
  }

  .tbc__btn {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.875rem 1rem;
    text-decoration: none;
    border: var(--ink-medium) solid var(--color-ink);
    cursor: pointer;
    transition:
      transform 150ms var(--ease-snap),
      box-shadow 150ms var(--ease-snap);
  }

  .tbc__btn-top {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .tbc__btn-icon {
    font-size: 1rem;
  }

  .tbc__btn-label {
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .tbc__btn-handle {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-ink-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Primary (email) */
  .tbc__btn--primary {
    background-color: var(--color-ink);
    color: var(--color-paper);
    box-shadow: 4px 4px 0 0 var(--color-shatta);
    padding: 1rem 1.25rem;
  }

  .tbc__btn--primary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 0 var(--color-shatta);
    color: var(--color-paper);
  }

  .tbc__btn--primary:active {
    transform: translate(2px, 2px);
    box-shadow: 0 0 0 0 var(--color-shatta);
  }

  .tbc__btn--primary .tbc__btn-handle {
    color: var(--color-paper-shadow);
  }

  .tbc__btn--primary .tbc__btn-label {
    font-size: 1.1rem;
  }

  /* Secondary (others) */
  .tbc__btn--secondary {
    background-color: var(--color-paper);
    color: var(--color-ink);
    box-shadow: 3px 3px 0 0 var(--color-ink);
  }

  .tbc__btn--secondary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 0 var(--color-ink);
  }

  .tbc__btn--secondary:active {
    transform: translate(2px, 2px);
    box-shadow: 0 0 0 0 var(--color-ink);
  }

  /* ─── COPY HINT ──────────────────────────────────────────────── */
  .tbc__copy-hint {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-ink-faded);
    margin: -0.25rem 0 0;
    letter-spacing: 0.03em;
    transition: color 200ms ease;
  }

  .tbc__copy-hint kbd {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 0.1em 0.35em;
    border: 1px solid var(--color-ink-faded);
    border-radius: 3px;
    background-color: var(--color-paper-grain);
  }

  .tbc__copy-hint--copied {
    color: var(--color-shatta);
  }

  .tbc__signature {
    font-family: var(--font-mono);
    font-style: italic;
    font-size: 0.9rem;
    color: var(--color-ink-faded);
    margin: 0;
  }

  .tbc__signature-nick {
    font-style: normal;
    color: var(--color-ink-faded);
    opacity: 0.7;
  }

  /* ─── ACCENT: SHATTA + YO! (knee-height sidekick, not co-lead) ── */
  .tbc__figure {
    display: flex;
    justify-content: center;
    align-items: flex-end;
  }

  .tbc__panel {
    position: relative;
    border: none;
    background-color: transparent;
    overflow: visible;
    /* knee-height accent: small, not a half-page figure */
    width: clamp(7rem, 18vw, 10rem);
    padding-top: 2.75rem; /* room for the shout bubble above his head */
  }

  .tbc__image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    margin: 0 auto;
  }

  /* YO! shout floats just above Shatta's head, tail pointing down at him */
  .tbc__bubble {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%) rotate(-3deg);
    z-index: 5;
  }

  /* ─── MOBILE (stacks cleanly at 320px) ───────────────────────── */
  @media (max-width: 767px) {
    .tbc {
      padding: var(--spacing-section) var(--spacing-sm);
    }

    .tbc__channels {
      grid-template-columns: 1fr;
      max-width: none;
    }

    /* Shatta drops below the content as a centered closing beat */
    .tbc__figure {
      order: 1;
      justify-content: center;
    }

    .tbc__panel {
      width: clamp(7rem, 38vw, 9rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tbc__btn {
      transition: none;
    }
  }
</style>

<script>
  const hint = document.querySelector('.tbc__copy-hint');
  if (hint) {
    const email = hint.getAttribute('data-email');
    const original = hint.innerHTML;

    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        if (email) {
          navigator.clipboard.writeText(email).then(() => {
            hint.textContent = 'copied!';
            hint.classList.add('tbc__copy-hint--copied');
            setTimeout(() => {
              hint.innerHTML = original;
              hint.classList.remove('tbc__copy-hint--copied');
            }, 1500);
          });
        }
      }
    });
  }
</script>
