---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import ChapterCover from '@components/ui/ChapterCover.astro';
import ChapterNav from '@components/ui/ChapterNav.astro';
import InkButton from '@components/ui/InkButton.astro';
import { projects, getAdjacentProjects, type Project } from '@data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;

/* First sentence of a tagline — keeps prev/next subtitles tight. */
function shortTagline(tagline: string): string {
  const firstSentence = tagline.split('. ')[0];
  return firstSentence.endsWith('.') ? firstSentence : `${firstSentence}.`;
}

/* "01", "02" … story-beat numbering for the case-file labels. */
function beatNumber(i: number): string {
  return String(i + 1).padStart(2, '0');
}

const { prev, next } = getAdjacentProjects(project.slug);

const prevItem = prev
  ? { title: prev.name, subtitle: shortTagline(prev.tagline), href: `/projects/${prev.slug}` }
  : null;

const nextItem = next
  ? { title: next.name, subtitle: shortTagline(next.tagline), href: `/projects/${next.slug}` }
  : {
      title: 'ALL PROJECTS',
      subtitle: '// back to the index',
      href: '/projects',
      direction: 'Back to Projects →',
    };

const statusSlug = project.status.toLowerCase().replace(/[\s-]/g, '');

const facts = [
  { label: 'YEAR', value: project.year },
  { label: 'ROLE', value: project.role },
  ...(project.client ? [{ label: 'CLIENT', value: project.client }] : []),
];

const links = [
  project.links.live && { href: project.links.live, label: 'Live Site ↗', variant: 'primary' as const },
  project.links.repo && { href: project.links.repo, label: 'Source ↗', variant: 'secondary' as const },
  project.links.demo && { href: project.links.demo, label: 'Demo', variant: 'ghost' as const },
  ...(project.links.also ?? []).map((l) => ({ href: l.href, label: l.label, variant: 'ghost' as const })),
].filter(Boolean) as { href: string; label: string; variant: 'primary' | 'secondary' | 'ghost' }[];

/* Preload whichever image paints the hero panel first. */
const heroImage = project.video?.poster ?? project.art;
---

<BaseLayout
  title={`${project.name} — Mohamed Shaban | she3bo`}
  description={shortTagline(project.tagline)}
>
  <Fragment slot="head">
    {heroImage && <link rel="preload" as="image" href={heroImage} />}
  </Fragment>

  <main class="inner-page">
    <Breadcrumb
      crumbs={[
        { label: 'CH 05', href: '/' },
        { label: 'PROJECTS', href: '/projects' },
        { label: project.name },
      ]}
    />
    <ChapterCover
      chapter={`CH 05.${project.number}`}
      arc={project.status}
      title={project.name}
      subtitle="// the case study"
    />

    <div class="case">
      {/* ── Intro: hero panel + lead ─────────────────────────────── */}
      <section class="case__intro">
        {project.video ? (
          <figure class="case__keyart case__keyart--motion">
            <video
              class="case__motion-video"
              autoplay
              muted
              loop
              playsinline
              poster={project.video.poster}
              width="1600"
              height="900"
              aria-label={`${project.name} key art, animated`}
            >
              {project.video.webm && <source src={project.video.webm} type="video/webm" />}
              <source src={project.video.mp4} type="video/mp4" />
            </video>
            <span class="case__motion-stamp" aria-hidden="true">Animated<br />Panel</span>
            {project.video.caption && (
              <figcaption class="case__panel-caption">// {project.video.caption}</figcaption>
            )}
            {/* Enhancement only — without JS the video still autoplays natively.
                Reduced-motion users get a still poster with controls instead. */}
            <script is:inline>
              (() => {
                const v = document.querySelector('.case__motion-video');
                if (!v) return;
                if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
                  v.removeAttribute('autoplay');
                  v.pause();
                  v.controls = true;
                } else if ('IntersectionObserver' in window) {
                  new IntersectionObserver(
                    (entries) => {
                      for (const e of entries) {
                        if (e.isIntersecting) v.play().catch(() => {});
                        else v.pause();
                      }
                    },
                    { threshold: 0.15 }
                  ).observe(v);
                }
              })();
            </script>
          </figure>
        ) : (
          project.art && (
            <figure class="case__keyart">
              <img
                src={project.art}
                alt={`${project.name} key art`}
                loading="eager"
                fetchpriority="high"
                decoding="async"
                width="1600"
                height="894"
              />
            </figure>
          )
        )}

        <p class="case__lead">{project.tagline}</p>
      </section>

      {/* ── Case file rail: status, facts, stack, links ──────────── */}
      <aside class="case__rail" aria-label={`${project.name} case file`}>
        <div class="case__file">
          <div class="case__file-head">
            <span class="case__icon" aria-hidden="true">{project.icon}</span>
            <span class={`case__status case__status--${statusSlug}`}>{project.status}</span>
          </div>

          <dl class="case__facts">
            {facts.map((f) => (
              <div class="case__fact">
                <dt class="case__fact-label">{f.label}</dt>
                <dd class="case__fact-value">{f.value}</dd>
              </div>
            ))}
          </dl>

          <div class="case__file-block">
            <h2 class="case__label case__label--file">// the stack</h2>
            <ul class="case__chips">
              {project.tech.map((t) => (
                <li class="case__chip">{t}</li>
              ))}
            </ul>
          </div>

          {links.length > 0 && (
            <div class="case__file-block">
              <h2 class="case__label case__label--file">// see it</h2>
              <div class="case__ctas">
                {links.map((l) => (
                  <InkButton href={l.href} variant={l.variant} size="sm">{l.label}</InkButton>
                ))}
              </div>
            </div>
          )}
        </div>
      </aside>

      {/* ── Body: numbers, brief, wins, story, panels ────────────── */}
      <div class="case__body">
        {project.metrics && project.metrics.length > 0 && (
          <section class="case__block" aria-labelledby="cs-numbers">
            <h2 id="cs-numbers" class="case__label">// the numbers</h2>
            <dl class="case__metrics">
              {project.metrics.map((m) => (
                <div class="case__metric">
                  <dt class="case__metric-label">{m.label}</dt>
                  <dd class="case__metric-value">{m.value}</dd>
                </div>
              ))}
            </dl>
          </section>
        )}

        <section class="case__block" aria-labelledby="cs-brief">
          <h2 id="cs-brief" class="case__label">// the brief</h2>
          <p class="case__desc">{project.description}</p>
        </section>

        {project.highlights.length > 0 && (
          <section class="case__block" aria-labelledby="cs-wins">
            <h2 id="cs-wins" class="case__label">// the wins</h2>
            <ul class="case__wins">
              {project.highlights.map((h) => (
                <li class="case__win">{h}</li>
              ))}
            </ul>
          </section>
        )}

        {project.story.map((section, i) => (
          <section class="case__block" aria-labelledby={`cs-story-${i}`}>
            <h2 id={`cs-story-${i}`} class="case__label">
              <span class="case__label-no">{beatNumber(i)}</span> // {section.label}
            </h2>
            <p class="case__desc">{section.body}</p>
          </section>
        ))}

        {project.gallery && project.gallery.length > 0 && (
          <section class="case__block" aria-labelledby="cs-panels">
            <h2 id="cs-panels" class="case__label">// the panels</h2>
            <div class="case__gallery">
              {project.gallery.map((g) => (
                <figure class="case__gallery-item">
                  <img
                    src={g.src}
                    srcset={`${g.src.replace('.webp', '-800.webp')} 800w, ${g.src} 1600w`}
                    sizes="(min-width: 1024px) 400px, (min-width: 768px) 45vw, 92vw"
                    alt={g.alt}
                    loading="lazy"
                    decoding="async"
                    width="1600"
                    height="894"
                  />
                  {g.caption && <figcaption class="case__panel-caption">// {g.caption}</figcaption>}
                </figure>
              ))}
            </div>
          </section>
        )}
      </div>
    </div>

    <ChapterNav prev={prevItem} next={nextItem} />
  </main>
</BaseLayout>

<style>
  .inner-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--spacing-md) var(--gutter) var(--spacing-xl);
  }

  /* Case-file grid: single column on mobile (intro → file card → body),
     reading column + sticky rail on desktop. */
  .case {
    max-width: 1160px;
    margin-top: var(--spacing-lg);
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    grid-template-areas:
      'intro'
      'rail'
      'body';
    gap: var(--spacing-lg);
  }

  @media (min-width: 1024px) {
    .case {
      grid-template-columns: minmax(0, 1fr) 320px;
      grid-template-areas:
        'intro rail'
        'body rail';
      align-items: start;
      column-gap: var(--spacing-lg);
    }

    /* The rail must stretch across both rows or the sticky card inside
       has zero scroll travel (its containing block collapses to content). */
    .case__rail {
      align-self: stretch;
    }
  }

  .case__intro {
    grid-area: intro;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .case__rail {
    grid-area: rail;
    min-width: 0;
  }

  .case__body {
    grid-area: body;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  /* Key-art panel — manga-framed hero, video or still. */
  .case__keyart {
    margin: 0;
    border: var(--ink-thick) solid var(--color-ink);
    box-shadow: 6px 6px 0 0 var(--color-shatta);
    background-color: var(--color-paper);
    line-height: 0;
  }

  .case__keyart img,
  .case__keyart video {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* The animated panel — chromeless living sketch with a rubber-stamp mark. */
  .case__keyart--motion {
    position: relative;
  }

  .case__motion-stamp {
    position: absolute;
    top: -0.85rem;
    right: 1.5rem;
    transform: rotate(-7deg);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-align: center;
    color: var(--color-shatta-deep);
    background-color: var(--color-paper);
    border: var(--ink-medium) solid var(--color-shatta-deep);
    padding: 0.3rem 0.55rem;
    user-select: none;
    pointer-events: none;
  }

  /* Mono caption under a panel — reads as a margin note. */
  .case__panel-caption {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.5;
    letter-spacing: 0.06em;
    color: var(--color-ink-muted);
    padding: 0.5rem 0.75rem;
    border-top: var(--ink-thin) solid var(--color-ink);
    background-color: var(--color-paper-grain);
  }

  .case__lead {
    font-family: var(--font-body);
    font-size: clamp(1.25rem, 1rem + 1.5vw, 1.75rem);
    font-weight: 700;
    line-height: 1.4;
    color: var(--color-ink);
    margin: 0;
    border-left: var(--ink-bold) solid var(--color-shatta);
    padding-left: var(--spacing-sm);
  }

  /* ── The case file card (rail) ─────────────────────────────────── */
  .case__file {
    border: var(--ink-thick) solid var(--color-ink);
    background-color: var(--color-paper);
    box-shadow: var(--ink-shadow);
    padding: var(--spacing-md);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  @media (min-width: 1024px) {
    .case__file {
      position: sticky;
      top: var(--spacing-md);
    }
  }

  .case__file-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-sm);
  }

  /* Emoji are full-color; heavy grayscale keeps them inside the
     three-color constitution — reads as inked glyph, not sticker. */
  .case__icon {
    font-size: 2.25rem;
    line-height: 1;
    filter: grayscale(0.9) contrast(1.05);
    opacity: 0.85;
  }

  .case__status {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    line-height: 1;
  }

  .case__status--live {
    background-color: var(--color-shatta);
    color: var(--color-paper);
  }

  .case__status--privatebeta {
    border: var(--ink-thin) dashed var(--color-ink);
    color: var(--color-ink);
  }

  .case__status--shipped {
    background-color: var(--color-ink);
    color: var(--color-paper);
  }

  /* ink-muted text: DESIGN.md 2.3 bans ink-faded text below 14px. */
  .case__status--demo,
  .case__status--archived {
    border: var(--ink-thin) solid var(--color-ink-faded);
    color: var(--color-ink-muted);
  }

  .case__status--pilot {
    border: var(--ink-thin) solid var(--color-shatta);
    color: var(--color-shatta-deep);
  }

  .case__status--opensource {
    border: var(--ink-thin) solid var(--color-ink);
    color: var(--color-ink);
  }

  /* Fact rows — the case-file metadata. */
  .case__facts {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    margin: 0;
    padding: var(--spacing-sm) 0;
    border-top: var(--ink-thin) solid var(--color-ink);
    border-bottom: var(--ink-thin) solid var(--color-ink);
  }

  .case__fact {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .case__fact-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--color-ink-muted);
    text-transform: uppercase;
  }

  .case__fact-value {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-ink);
    margin: 0;
  }

  .case__file-block {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .case__ctas {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--spacing-sm);
  }

  .case__ctas :global(.ink-btn) {
    width: 100%;
  }

  /* ── Body blocks ───────────────────────────────────────────────── */
  .case__block {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  /* shatta-deep, not shatta: at 12px mono this must clear WCAG AA 4.5:1
     on paper (shatta = 3.95:1, shatta-deep = 5.17:1). */
  .case__label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-shatta-deep);
    margin: 0;
  }

  .case__label--file {
    font-size: 0.7rem;
    color: var(--color-ink-muted);
  }

  /* Story-beat number — inked chapter marker ahead of the label. */
  .case__label-no {
    color: var(--color-paper);
    background-color: var(--color-ink);
    padding: 0.1rem 0.4rem;
    margin-right: 0.35rem;
  }

  .case__desc {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 65ch;
  }

  /* Power stats — manga sticker cards. */
  .case__metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: var(--spacing-sm);
    margin: 0;
  }

  .case__metric {
    display: flex;
    /* dt (label) first in DOM for valid dl semantics; value renders on top. */
    flex-direction: column-reverse;
    gap: 0.35rem;
    border: var(--ink-medium) solid var(--color-ink);
    background-color: var(--color-paper);
    box-shadow: var(--ink-shadow-sm);
    padding: 0.9rem 1rem;
  }

  .case__metric-value {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1;
    letter-spacing: 0.02em;
    color: var(--color-ink);
    margin: 0;
  }

  /* One red stat per case file — the headline number. */
  .case__metric:first-child .case__metric-value {
    color: var(--color-shatta);
  }

  .case__metric-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  /* Wins — manga action list with red tick markers. */
  .case__wins {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    max-width: 65ch;
  }

  .case__win {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    padding-left: 1.25rem;
    position: relative;
  }

  .case__win::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--color-shatta);
    font-weight: 700;
  }

  .case__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .case__chip {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-ink);
    border: var(--ink-thin) solid var(--color-ink);
    padding: 0.3rem 0.65rem;
    letter-spacing: 0.04em;
    background-color: var(--color-paper);
  }

  /* Gallery — sketch panels, two-up on wide screens.
     An odd first panel goes full-width so no slot sits empty. */
  .case__gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-sm);
  }

  @media (min-width: 768px) {
    .case__gallery {
      grid-template-columns: repeat(2, 1fr);
    }

    .case__gallery-item:first-child:nth-last-child(odd) {
      grid-column: 1 / -1;
    }
  }

  .case__gallery-item {
    margin: 0;
    border: var(--ink-thick) solid var(--color-ink);
    background-color: var(--color-paper);
    box-shadow: var(--ink-shadow-sm);
    line-height: 0;
    transition:
      transform 280ms var(--ease-hover),
      box-shadow 280ms var(--ease-hover);
  }

  .case__gallery-item:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 0 var(--color-ink);
  }

  .case__gallery-item img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 480px) {
    .case__file-head {
      flex-wrap: wrap;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .case__gallery-item {
      transition: none;
    }

    .case__gallery-item:hover {
      transform: none;
      box-shadow: var(--ink-shadow-sm);
    }
  }
</style>
