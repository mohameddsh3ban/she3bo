---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import SpeechBubble from '@components/ui/SpeechBubble.astro';
import { channels } from '@data/channels';

const email = channels.find((c) => c.primary)!;
const socials = channels.filter((c) => !c.primary);

const details = [
  { k: 'BASED IN', v: 'Cairo, Egypt' },
  { k: 'SHIPPING AT', v: 'm2a-fm GmbH · Germany (remote)' },
  { k: 'REPLIES IN', v: 'a day — usually less' },
  { k: 'LANGUAGES', v: 'Arabic · English' },
];
---

<BaseLayout
  title="Contact — Mohamed Shaban | she3bo"
  description="Reach Mohamed Shaban (she3bo) — senior full-stack developer. Email, GitHub, LinkedIn, Instagram. The portfolio ends here; the conversation starts wherever you want."
>
  <main class="contact">
    <Breadcrumb crumbs={[{ label: 'CH 06', href: '/' }, { label: 'CONTACT' }]} />

    <!-- ─── HERO: the signoff ─────────────────────────────────── -->
    <header class="contact__hero">
      <div class="contact__meta">
        <span class="contact__chapter">CH 06</span>
        <span class="contact__sep">──</span>
        <span class="contact__arc">TO BE CONTINUED</span>
      </div>

      <div class="contact__hero-grid">
        <div class="contact__hero-text">
          <h1 class="contact__title">LET&rsquo;S<br />TALK.</h1>
          <p class="contact__lead">
            The portfolio ends here. The conversation starts wherever you want.
          </p>
          <p class="contact__avail">
            <span class="contact__avail-dot" aria-hidden="true"></span>
            Senior full-stack — open to the right team. Remote or relocate.
          </p>

          <!-- Primary CTA: email -->
          <a class="contact__email" href={email.href} aria-label={`Email — ${email.handle}`}>
            <span class="contact__email-top">
              <span class="contact__email-icon">{email.icon}</span>
              <span class="contact__email-label">EMAIL ME</span>
              <span class="contact__email-arrow" aria-hidden="true">↗</span>
            </span>
            <span class="contact__email-handle">{email.handle}</span>
          </a>
          <button type="button" class="contact__copy-hint" data-email={email.handle} aria-label={`Copy email address ${email.handle}`}>
            <kbd>CTRL</kbd> + <kbd>K</kbd> to copy
          </button>
        </div>

        <!-- Duo signoff: Sheb3o waving + Shatta YO! -->
        <div class="contact__figure">
          <svg class="contact__bracket contact__bracket--tl" width="34" height="34" aria-hidden="true"><path d="M0 34 L0 0 L34 0" fill="none" stroke="var(--color-ink)" stroke-width="3"/></svg>
          <svg class="contact__bracket contact__bracket--br" width="34" height="34" aria-hidden="true"><path d="M34 0 L34 34 L0 34" fill="none" stroke="var(--color-ink)" stroke-width="3"/></svg>
          <img
            class="contact__sheb3o"
            src="/she3bo/sheb3o-wave.webp"
            alt="Sheb3o waving — see you next chapter"
            width="600"
            height="800"
            loading="eager"
          />
          <div class="contact__shatta">
            <div class="contact__bubble">
              <SpeechBubble text="YO!" tail="down" variant="shout" />
            </div>
            <img src="/shata/shatta-yo.png" alt="" aria-hidden="true" width="160" height="160" loading="lazy" />
          </div>
        </div>
      </div>

      <hr class="contact__divider" />
    </header>

    <!-- ─── CHANNELS ──────────────────────────────────────────── -->
    <section class="contact__channels" aria-label="Other ways to reach me">
      <p class="contact__channels-label">// or find me on</p>
      <div class="contact__channel-grid">
        {socials.map((ch) => (
          <a
            class="contact__channel"
            href={ch.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${ch.label} — ${ch.handle}`}
          >
            <span class="contact__channel-icon" aria-hidden="true">{ch.icon}</span>
            <span class="contact__channel-name">{ch.label}</span>
            <span class="contact__channel-handle">{ch.handle}</span>
            <span class="contact__channel-blurb">{ch.blurb}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- ─── DETAILS ───────────────────────────────────────────── -->
    <section class="contact__details" aria-label="Details">
      {details.map((d) => (
        <div class="contact__detail">
          <span class="contact__detail-k">{d.k}</span>
          <span class="contact__detail-v">{d.v}</span>
        </div>
      ))}
    </section>

    <!-- ─── CLOSING BEAT ──────────────────────────────────────── -->
    <footer class="contact__signoff">
      <p class="contact__signature">&mdash; Mohamed Shaban <span>(she3bo)</span></p>
      <span class="contact__tbc">to be continued&hellip;</span>
    </footer>
  </main>
</BaseLayout>

<style>
  .contact {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--spacing-md) var(--spacing-sm) var(--spacing-2xl);
  }

  /* ─── CHAPTER META ─── */
  .contact__meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: var(--spacing-md);
  }
  .contact__chapter { color: var(--color-shatta); font-weight: 700; }
  .contact__sep, .contact__arc { color: var(--color-ink-muted); }

  /* ─── HERO ─── */
  .contact__hero-grid {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: var(--spacing-lg);
    align-items: center;
  }
  .contact__hero-text { display: flex; flex-direction: column; gap: 1.25rem; }

  .contact__title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 11vw, 8rem);
    line-height: 0.82;
    color: var(--color-ink);
    margin: 0;
    letter-spacing: 0.01em;
  }

  .contact__lead {
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 1.4vw, 1.3rem);
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 42ch;
  }

  .contact__avail {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--color-ink);
    margin: 0;
    max-width: 42ch;
  }
  .contact__avail-dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--color-shatta);
    box-shadow: 0 0 0 3px rgba(214, 40, 40, 0.18);
    flex-shrink: 0;
  }

  /* Primary email CTA */
  .contact__email {
    display: inline-flex;
    flex-direction: column;
    gap: 0.3rem;
    width: fit-content;
    padding: 1rem 1.5rem;
    margin-top: 0.25rem;
    background: var(--color-ink);
    color: var(--color-paper);
    border: var(--ink-thick) solid var(--color-ink);
    text-decoration: none;
    box-shadow: 5px 5px 0 0 var(--color-shatta);
    transition: transform 150ms var(--ease-snap), box-shadow 150ms var(--ease-snap);
  }
  .contact__email:hover {
    transform: translate(-3px, -3px);
    box-shadow: 8px 8px 0 0 var(--color-shatta);
    color: var(--color-paper);
  }
  .contact__email:active { transform: translate(2px, 2px); box-shadow: 0 0 0 0 var(--color-shatta); }
  .contact__email-top { display: flex; align-items: center; gap: 0.6rem; }
  .contact__email-icon { font-size: 1.1rem; }
  .contact__email-label {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.06em;
  }
  .contact__email-arrow { margin-left: auto; font-family: var(--font-mono); opacity: 0.8; }
  .contact__email-handle {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-paper-shadow);
  }

  .contact__copy-hint {
    appearance: none;
    -webkit-appearance: none;
    background: none;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    width: fit-content;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-ink-faded);
    letter-spacing: 0.03em;
    padding: 0 0.25rem;
    margin: 0;
    -webkit-tap-highlight-color: transparent;
    transition: color 200ms ease;
  }
  .contact__copy-hint:hover { color: var(--color-ink); }
  .contact__copy-hint kbd {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 0.1em 0.4em;
    border: 1px solid var(--color-ink-faded);
    border-radius: 3px;
    background: var(--color-paper-grain);
  }
  .contact__copy-hint--copied { color: var(--color-shatta); }

  /* Hero figure: Sheb3o + Shatta */
  .contact__figure {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    padding: 1rem;
    min-height: 360px;
  }
  .contact__bracket { position: absolute; opacity: 0.55; }
  .contact__bracket--tl { top: 0; left: 0; }
  .contact__bracket--br { bottom: 0; right: 0; }
  .contact__sheb3o {
    max-width: 100%;
    max-height: 460px;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    filter: drop-shadow(6px 8px 0 rgba(26, 26, 26, 0.12));
  }
  .contact__shatta {
    position: absolute;
    right: 4%;
    bottom: 0;
    width: clamp(5.5rem, 9vw, 7.5rem);
    padding-top: 2.5rem;
  }
  .contact__shatta img { display: block; width: 100%; height: auto; }
  .contact__bubble {
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%) rotate(-3deg);
    z-index: 3;
  }

  .contact__divider {
    height: var(--ink-thick);
    background: var(--color-ink);
    border: none;
    margin: var(--spacing-lg) 0 0;
    position: relative;
  }
  .contact__divider::after {
    content: '';
    position: absolute; top: 0; left: 0;
    width: 80px; height: 100%;
    background: var(--color-shatta);
  }

  /* ─── CHANNELS ─── */
  .contact__channels { padding-top: var(--spacing-lg); }
  .contact__channels-label {
    font-family: var(--font-mono);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    margin: 0 0 var(--spacing-sm);
  }
  .contact__channel-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-sm);
  }
  .contact__channel {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1.25rem;
    background: var(--color-paper);
    border: var(--ink-medium) solid var(--color-ink);
    text-decoration: none;
    color: var(--color-ink);
    box-shadow: 4px 4px 0 0 var(--color-ink);
    transition: transform 150ms var(--ease-snap), box-shadow 150ms var(--ease-snap), background-color 150ms var(--ease-ink);
  }
  .contact__channel:hover {
    transform: translate(-3px, -3px);
    box-shadow: 7px 7px 0 0 var(--color-shatta);
  }
  .contact__channel:active { transform: translate(2px, 2px); box-shadow: 0 0 0 0 var(--color-shatta); }
  .contact__channel-icon { font-size: 1.4rem; line-height: 1; }
  .contact__channel-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    letter-spacing: 0.06em;
  }
  .contact__channel-handle {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-ink);
  }
  .contact__channel-blurb {
    font-family: var(--font-mono);
    font-style: italic;
    font-size: 0.72rem;
    color: var(--color-ink-faded);
  }

  /* ─── DETAILS ─── */
  .contact__details {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-sm);
    margin-top: var(--spacing-lg);
    padding-top: var(--spacing-md);
    border-top: var(--ink-thin) dashed var(--color-ink-faded);
  }
  .contact__detail { display: flex; flex-direction: column; gap: 0.3rem; }
  .contact__detail-k {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    color: var(--color-shatta);
    font-weight: 700;
  }
  .contact__detail-v {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-ink);
    line-height: 1.4;
  }

  /* ─── SIGNOFF ─── */
  .contact__signoff {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: var(--spacing-xl);
  }
  .contact__signature {
    font-family: var(--font-mono);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--color-ink-faded);
    margin: 0;
  }
  .contact__signature span { opacity: 0.7; }
  .contact__tbc {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--color-shatta);
    transform: rotate(-4deg);
    letter-spacing: 0.02em;
  }

  /* ─── TABLET / MOBILE (spec breakpoint: <768) ─── */
  @media (max-width: 767px) {
    .contact__hero-grid { grid-template-columns: 1fr; gap: var(--spacing-md); }
    .contact__figure { order: -1; min-height: auto; }
    .contact__sheb3o { max-height: 340px; }
    .contact__channel-grid { grid-template-columns: 1fr; }
    .contact__details { grid-template-columns: 1fr 1fr; }
    /* full-width email CTA + wrap the handle so it can't overflow 320px */
    .contact__email { width: 100%; }
    .contact__email-handle { overflow-wrap: anywhere; }
  }
  @media (max-width: 420px) {
    .contact__details { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact__email, .contact__channel { transition: none; }
  }
</style>

<script>
  function initContactCopy() {
    const hint = document.querySelector<HTMLElement>('.contact__copy-hint');
    if (!hint || hint.dataset.wired) return;
    hint.dataset.wired = '1';
    const email = hint.getAttribute('data-email');
    const coarse = window.matchMedia('(pointer: coarse)').matches;
    // touch devices have no Ctrl+K — show a tappable label instead
    const idle = coarse ? 'TAP TO COPY EMAIL ↗' : '<kbd>CTRL</kbd> + <kbd>K</kbd> to copy';
    if (coarse) hint.textContent = 'TAP TO COPY EMAIL ↗';

    function copy() {
      if (!email || !navigator.clipboard) return;
      navigator.clipboard.writeText(email).then(() => {
        hint.textContent = 'COPIED!';
        hint.classList.add('contact__copy-hint--copied');
        setTimeout(() => {
          hint.innerHTML = idle;
          hint.classList.remove('contact__copy-hint--copied');
        }, 1500);
      });
    }

    hint.addEventListener('click', copy);
    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        copy();
      }
    });
  }
  document.addEventListener('astro:page-load', initContactCopy);
</script>
