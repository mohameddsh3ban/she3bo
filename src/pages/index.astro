  /* ─── FINAL CTA ─── */
  .final-cta {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: center;
  }
  .cta-asset-group {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
