---
import BaseLayout from '@layouts/BaseLayout.astro';
import InkButton from '@components/ui/InkButton.astro';
import NavFloatingButtons from '@components/nav/NavFloatingButtons.astro';
import ExperienceMangaPage from '@components/experience/ExperienceMangaPage.astro';
import About from '@components/sections/About.astro';
import SkillsDomainCards from '@components/sections/SkillsDomainCards.astro';
import ProjectsFinal from '@components/sections/ProjectsFinal.astro';
import Contact from '@components/sections/ContactToBeContinued.astro';
---

<BaseLayout
  title="Mohamed Shaban — Senior Full-Stack Developer"
  description="Senior full-stack developer. Built like I train. Spicy by default."
>
  <NavFloatingButtons activeLink="#experience" />

  <main>
  {/* ─── HERO PLACEHOLDER (Chunk 2 will flesh this out) ───────── */}
  <section class="hero">
    <div class="hero__container">
      <div class="hero__text">
        <p class="hero__nickname">they call me <span class="ink-underline">she3bo</span></p>
        <h1 class="hero__name">
          MOHAMED
          <br />
          SHABAN
        </h1>
        <p class="hero__tagline">
          Senior full-stack developer.
          <br />
          Built like I train.
          <br />
          <span class="hero__tagline-spicy">Spicy by default.</span>
        </p>
        <div class="hero__ctas">
          <InkButton href="#projects" variant="primary" size="lg">
            See My Work
          </InkButton>
          <InkButton href="#contact" variant="secondary" size="lg">
            Get In Touch
          </InkButton>
        </div>
      </div>

      <div class="hero__figure">
        <img
          src="/sheb3o-hero.png"
          alt="Sheb3o — Mohamed Shaban illustration with shatta mascot"
          class="hero__image"
          width="800"
          height="800"
        />
      </div>
    </div>

    <div class="hero__scroll-cue">
      <span>scroll</span>
      <span class="hero__scroll-arrow">↓</span>
    </div>
  </section>

  {/* ─── EXPERIENCE ────────────────────────────────────────────── */}
  <ExperienceMangaPage />

  {/* ─── ABOUT ─────────────────────────────────────────────────── */}
  <About />

  {/* ─── SKILLS ────────────────────────────────────────────────── */}
  <SkillsDomainCards />

  {/* ─── PROJECTS ──────────────────────────────────────────────── */}
  <ProjectsFinal />

  {/* ─── CONTACT ──────────────────────────────────────────────── */}
  <Contact />
  </main>
</BaseLayout>

<style>
  /* ─── HERO ───────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-md);
    overflow: hidden;
  }

  .hero__container {
    width: 100%;
    max-width: 1400px;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-lg);
    align-items: end;
  }

  @media (min-width: 1024px) {
    .hero__container {
      grid-template-columns: 1fr 1fr;
      gap: 0;
    }
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    padding-bottom: var(--spacing-xl);
  }

  .hero__nickname {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    text-transform: lowercase;
    letter-spacing: 0.1em;
    color: var(--color-ink-faded);
    margin: 0;
  }

  .hero__name {
    font-size: clamp(3.5rem, 12vw, 9rem);
    line-height: 0.85;
    margin: 0;
    color: var(--color-ink);
    font-weight: 400;
  }

  .hero__tagline {
    font-family: var(--font-body);
    font-size: clamp(1.1rem, 1.8vw, 1.5rem);
    line-height: 1.5;
    color: var(--color-ink-muted);
    max-width: 30ch;
    margin: 0;
  }

  .hero__tagline-spicy {
    color: var(--color-shatta);
    font-weight: 700;
    font-style: italic;
    position: relative;
  }

  .hero__tagline-spicy::after {
    content: '🌶️';
    margin-left: 0.25rem;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-sm);
  }

  /* ─── HERO FIGURE ─────────────────────────────────────────────── */
  .hero__figure {
    position: relative;
    height: 85vh;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .hero__image {
    height: 100%;
    width: auto;
    max-width: none;
    object-fit: contain;
    object-position: center bottom;
  }

  /* ─── SCROLL CUE ─────────────────────────────────────────────── */
  .hero__scroll-cue {
    position: absolute;
    bottom: var(--spacing-md);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-ink-faded);
    animation: bob 2s ease-in-out infinite;
  }

  .hero__scroll-arrow {
    font-size: 1.5rem;
  }

  @keyframes bob {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

</style>
