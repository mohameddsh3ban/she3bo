---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
---

<BaseLayout
  title="Mohamed Shaban (she3bo) — Senior Full-Stack Developer"
  description="Senior full-stack developer from Egypt, currently shipping at m2a-fm GmbH in Germany. Built like a train. Spicy by default."
>
  {/* LCP image — start fetching before layout. Media queries mirror the <picture>. */}
  <link slot="head" rel="preload" as="image" imagesrcset="/she3bo/sheb3o-hero-mobile-400.webp 400w, /she3bo/sheb3o-hero-mobile.webp 540w" imagesizes="48vw" media="(max-width: 768px)" fetchpriority="high" />
  <link slot="head" rel="preload" as="image" imagesrcset="/she3bo/sheb3o-hero-768.webp 768w, /she3bo/sheb3o-hero.webp 1024w" imagesizes="580px" media="(min-width: 769px)" fetchpriority="high" />

  <main class="home-c2">

    <!-- STICKY SPINE TOC (desktop only) -->
    <nav class="chapter-spine" aria-label="Chapter navigation">
      <div class="spine-connector" aria-hidden="true"></div>
      <a href="#ch-1" data-target="ch-1" data-chapter-title="HERO" class="spine-marker" aria-label="Chapter I — Hero">
        <span class="marker-circle"><span class="marker-numeral">I</span></span>
        <span class="marker-tick" aria-hidden="true"></span>
        <span class="marker-label">I — HERO</span>
      </a>
      <a href="#ch-2" data-target="ch-2" data-chapter-title="STATS" class="spine-marker" aria-label="Chapter II — Stats">
        <span class="marker-circle"><span class="marker-numeral">II</span></span>
        <span class="marker-tick" aria-hidden="true"></span>
        <span class="marker-label">II — STATS</span>
      </a>
      <a href="#ch-3" data-target="ch-3" data-chapter-title="VOLUME ONE" class="spine-marker" aria-label="Chapter III — Volume One">
        <span class="marker-circle"><span class="marker-numeral">III</span></span>
        <span class="marker-tick" aria-hidden="true"></span>
        <span class="marker-label">III — VOLUME ONE</span>
      </a>
      <a href="#ch-4" data-target="ch-4" data-chapter-title="ORIGIN STORY" class="spine-marker" aria-label="Chapter IV — Origin Story">
        <span class="marker-circle"><span class="marker-numeral">IV</span></span>
        <span class="marker-tick" aria-hidden="true"></span>
        <span class="marker-label">IV — ORIGIN STORY</span>
      </a>
      <a href="#ch-5" data-target="ch-5" data-chapter-title="POWER MOVES" class="spine-marker" aria-label="Chapter V — Power Moves">
        <span class="marker-circle"><span class="marker-numeral">V</span></span>
        <span class="marker-tick" aria-hidden="true"></span>
        <span class="marker-label">V — POWER MOVES</span>
      </a>
      <a href="#ch-6" data-target="ch-6" data-chapter-title="TO BE CONTINUED" class="spine-marker" aria-label="Chapter VI — To Be Continued">
        <span class="marker-circle"><span class="marker-numeral">VI</span></span>
        <span class="marker-tick" aria-hidden="true"></span>
        <span class="marker-label">VI — TO BE CONTINUED</span>
      </a>
      <img class="spine-shatta" src="/shata/shatta-powerup.webp" alt="Shatta climbing the chapters" width="96" height="160" decoding="async" />
    </nav>

    <!-- CONTENT COLUMN -->
    <div class="content-col">

      <!-- HERO (no mini-cover — hero IS the cover) -->
      <section class="chapter-section hero-section" id="ch-1" data-chapter="I">
        <div class="hero">
          <span class="hero-stamp" aria-hidden="true">VOL. 01 &middot; COVER</span>
          <div class="hero-content">
            <p class="hero-status">
              <span class="hero-status__dot" aria-hidden="true"></span>
              CURRENT ARC: TECH LEAD &middot; PILOT 100 @ M2A-FM, GERMANY
            </p>
            <p class="hero-nickname">they call me she3bo</p>
            <h1 class="hero-name">
              MOHAMED SHABAN
              <svg class="name-underline" viewBox="0 0 120 6" preserveAspectRatio="none" aria-hidden="true"><path class="name-underline__path" d="M0 3 Q15 0 30 3 Q45 6 60 3 Q75 0 90 3 Q105 6 120 3" fill="none" stroke="var(--color-shatta)" stroke-width="4" stroke-linecap="round" pathLength="100"/></svg>
            </h1>
            <div class="hero-tagline">
              <p>Senior full-stack developer.</p>
              <p>Built like a train.</p>
              <p class="tagline-spicy">Spicy by default. <span class="chili" title="AKL NAR!">🌶️</span></p>
            </div>
            <div class="hero-ctas">
              <a href="/projects" class="btn btn-primary">SEE MY WORK</a>
              <a href="/contact" class="btn btn-secondary">GET IN TOUCH</a>
            </div>
            <a href="/cv.pdf" target="_blank" rel="noopener" class="cv-link">or download CV <span class="cv-arrow">↗</span></a>
          </div>
          <div class="hero-asset">
            <span class="hero-burst" aria-hidden="true"></span>
            <picture>
              {/* mobile gets a tight character crop so he reads BIG in the narrow column */}
              <source media="(max-width: 768px)" srcset="/she3bo/sheb3o-hero-mobile-400.webp 400w, /she3bo/sheb3o-hero-mobile.webp 540w" sizes="48vw" width="540" height="930" />
              <img src="/she3bo/sheb3o-hero.webp" srcset="/she3bo/sheb3o-hero-768.webp 768w, /she3bo/sheb3o-hero.webp 1024w" sizes="580px" alt="Sheb3o standing with Shatta the chili pepper sidekick, HUFTO! moment" width="1024" height="1024" fetchpriority="high" decoding="async" />
            </picture>
          </div>
          <span class="hero-scrollcue" aria-hidden="true">scroll &darr;</span>
        </div>
      </section>

      <!-- CHAPTER I — STATS -->
      <section class="chapter-section" id="ch-2" data-chapter="II">
        <div class="mini-cover">
          <span class="chapter-number">I</span>
          <div class="mini-cover-text">
            <h2 class="mini-cover-title">THE STATS</h2>
            <p class="mini-cover-subtitle">// the protagonist's stats</p>
          </div>
          <div class="mini-cover-divider"><span class="divider-accent"></span></div>
        </div>
        <div class="stats-strip">
          <div class="stats-grid">
            <div class="stat reveal">
              <span class="stat-number">4+</span>
              <span class="stat-label">years writing production code</span>
            </div>
            <div class="stat reveal" data-reveal-delay="80">
              <span class="stat-number">{projects.length}</span>
              <span class="stat-label">case studies · 30+ projects delivered</span>
            </div>
            <div class="stat reveal" data-reveal-delay="160">
              <span class="stat-number">10,000+</span>
              <span class="stat-label">users served in production</span>
            </div>
            <div class="stat reveal" data-reveal-delay="240">
              <span class="stat-number">300+</span>
              <span class="stat-label">REST endpoints designed &amp; owned</span>
            </div>
            <div class="stat reveal" data-reveal-delay="320">
              <span class="stat-number">3</span>
              <span class="stat-label">production codebases owned solo</span>
            </div>
            <div class="stat reveal" data-reveal-delay="400">
              <span class="stat-number">92%</span>
              <span class="stat-label">load time cut on a legacy ERP</span>
            </div>
          </div>
          <div class="stats-asset reveal" data-reveal-delay="120">
            <picture>
              {/* mobile gets the tight flex crop so he reads BIG, mirroring the hero */}
              <source media="(max-width: 768px)" srcset="/she3bo/sheb3o-flex-mobile-400.webp 400w, /she3bo/sheb3o-flex-mobile.webp 460w" sizes="48vw" width="460" height="901" />
              <img src="/she3bo/sheb3o-flex.webp" srcset="/she3bo/sheb3o-flex-600.webp 452w, /she3bo/sheb3o-flex.webp 603w" sizes="302px" alt="Sheb3o flexing" width="603" height="800" loading="lazy" decoding="async" />
            </picture>
            <img class="stats-shatta" src="/shata/shatta-flex.webp" alt="Shatta flexing in solidarity" width="121" height="200" loading="lazy" decoding="async" />
          </div>
        </div>
      </section>

      <!-- CHAPTER II — FEATURED (auto-rotating project carousel) -->
      <section class="chapter-section" id="ch-3" data-chapter="III">
        <div class="mini-cover">
          <span class="chapter-number">II</span>
          <div class="mini-cover-text">
            <h2 class="mini-cover-title">VOLUME ONE</h2>
            <p class="mini-cover-subtitle">// the case files — flipping through</p>
          </div>
          <div class="mini-cover-divider"><span class="divider-accent"></span></div>
        </div>

        <div class="pcarousel reveal" data-carousel aria-roledescription="carousel" aria-label="Featured projects, auto-rotating">
          <img class="pcarousel__shatta" src="/shata/shatta-point.webp" alt="" aria-hidden="true" width="140" height="140" loading="lazy" decoding="async" />
          <div class="pcarousel__viewport" data-carousel-track>
            {projects.map((p, i) => (
              <article class="pcard" data-carousel-slide aria-roledescription="slide" aria-label={`Project ${i + 1} of ${projects.length}: ${p.name}`}>
                <div class="pcard__top">
                  <span class="pcard__num">CASE {p.number}</span>
                  <span class:list={['status-pill', p.status === 'LIVE' ? 'status-live' : 'status-forged']}>{p.status}</span>
                </div>
                <h3 class="pcard__name">{p.name}</h3>
                <p class="pcard__tagline">{p.tagline}</p>
                <div class="tech-chips">
                  {p.tech.slice(0, 6).map((t) => <span class="chip">{t}</span>)}
                </div>
                <a href={`/projects/${p.slug}`} class="btn btn-primary pcard__cta">&rarr; Read the case study</a>
              </article>
            ))}
          </div>
        </div>

        <div class="pcarousel__dots" data-carousel-dots role="tablist" aria-label="Choose a project">
          {projects.map((p, i) => (
            <button type="button" role="tab" class="pdot" data-carousel-dot data-index={i} aria-label={`Show ${p.name}`} aria-selected={i === 0 ? 'true' : 'false'}></button>
          ))}
        </div>

        <a href="/projects" class="see-all cta-link">&rarr; See all {projects.length} projects</a>
      </section>

      <!-- COMIC TRANSITION -->
      <div class="comic-transition" aria-hidden="true">
        <span class="transition-line"></span>
        <span class="transition-text transition-next">NEXT CHAPTER</span>
        <span class="transition-line"></span>
      </div>

      <!-- CHAPTER III — ABOUT -->
      <section class="chapter-section" id="ch-4" data-chapter="IV">
        <div class="mini-cover">
          <span class="chapter-number">III</span>
          <div class="mini-cover-text">
            <h2 class="mini-cover-title">ORIGIN STORY</h2>
            <p class="mini-cover-subtitle">// origin story</p>
          </div>
          <div class="mini-cover-divider"><span class="divider-accent"></span></div>
        </div>
        <div class="about-layout reveal">
          <div class="about-asset">
            <img src="/she3bo/sheb3o-coding.webp" srcset="/she3bo/sheb3o-coding-640.webp 640w, /she3bo/sheb3o-coding.webp 1000w" sizes="(max-width: 768px) 372px, 480px" alt="Sheb3o coding with Shatta cheering TPE!" width="1000" height="754" loading="lazy" decoding="async" />
          </div>
          <div class="about-content">
            <p class="about-hook">Senior full-stack from Egypt, leading frontend across three production codebases at M2A-FM GmbH in Germany. Code is just my dialect — the real work is reading the problem before writing the solution.</p>
            <a href="/about" class="cta-link">→ The full story</a>
          </div>
        </div>
      </section>

      <!-- CHAPTER IV — TECHNIQUES -->
      <section class="chapter-section" id="ch-5" data-chapter="V">
        <div class="mini-cover">
          <span class="chapter-number">IV</span>
          <div class="mini-cover-text">
            <h2 class="mini-cover-title">POWER MOVES</h2>
            <p class="mini-cover-subtitle">// power moves manual</p>
          </div>
          <div class="mini-cover-divider"><span class="divider-accent"></span></div>
        </div>
        <div class="techniques-grid">
          <div class="technique-row reveal">
            <span class="tech-name">ANGULAR</span>
            <div class="power-bar-track"><div class="power-bar-fill" style="width:100%"></div></div>
          </div>
          <div class="technique-row reveal">
            <span class="tech-name">NESTJS</span>
            <div class="power-bar-track"><div class="power-bar-fill" style="width:100%"></div></div>
          </div>
          <div class="technique-row reveal">
            <span class="tech-name">TYPESCRIPT</span>
            <div class="power-bar-track"><div class="power-bar-fill" style="width:100%"></div></div>
          </div>
          <div class="technique-row reveal">
            <span class="tech-name">POSTGRESQL</span>
            <div class="power-bar-track"><div class="power-bar-fill" style="width:100%"></div></div>
          </div>
          <div class="technique-row reveal">
            <span class="tech-name">RXJS</span>
            <div class="power-bar-track"><div class="power-bar-fill" style="width:90%"></div></div>
          </div>
          <div class="technique-row reveal">
            <span class="tech-name">CODE REVIEW</span>
            <div class="power-bar-track"><div class="power-bar-fill" style="width:100%"></div></div>
          </div>
        </div>
        <a href="/skills" class="cta-link">→ See all techniques</a>
      </section>

      <!-- COMIC TRANSITION -->
      <div class="comic-transition" aria-hidden="true">
        <span class="transition-line"></span>
        <span class="transition-text transition-meanwhile">MEANWHILE....</span>
        <span class="transition-line"></span>
      </div>

      <!-- CHAPTER V — ARCS -->
      <section class="chapter-section" id="chapter-arcs">
        <div class="mini-cover">
          <span class="chapter-number">V</span>
          <div class="mini-cover-text">
            <h2 class="mini-cover-title">THE JOURNEY</h2>
            <p class="mini-cover-subtitle">// the journey so far</p>
          </div>
          <div class="mini-cover-divider"><span class="divider-accent"></span></div>
        </div>
        <div class="arcs-grid reveal">
          <article class="arc">
            <span class="arc-num">ARC 01</span>
            <h3 class="arc-name">FOUNDATION ARC</h3>
            <p class="arc-summary">Nearly three years modernizing a 10,000-user ERP in Kuwait.</p>
            <span class="status-pill status-forged">FORGED</span>
          </article>
          <article class="arc">
            <span class="arc-num">ARC 02</span>
            <h3 class="arc-name">TRAINING ARC</h3>
            <p class="arc-summary">One year off the keyboard. Discipline forged in a different dojo.</p>
            <span class="status-pill status-forged">FORGED</span>
          </article>
          <article class="arc arc-current">
            <span class="arc-num">ARC 03</span>
            <h3 class="arc-name">ASCENSION ARC</h3>
            <p class="arc-summary">Technical lead on Pilot 100 — an enterprise aviation exam platform, built from Germany.</p>
            <span class="status-pill status-current">CURRENT</span>
            <img class="arc-shatta-flag" src="/shata/shatta-flag.webp" alt="Shatta planting flag on current arc" width="82" height="120" loading="lazy" decoding="async" />
          </article>
        </div>
        <a href="/experience" class="cta-link">→ Read the full arcs</a>
      </section>

      <!-- CHAPTER VI — SIGNOFF -->
      <section class="chapter-section" id="ch-6" data-chapter="VI">
        <div class="mini-cover">
          <span class="chapter-number">VI</span>
          <div class="mini-cover-text">
            <h2 class="mini-cover-title">TO BE CONTINUED</h2>
            <p class="mini-cover-subtitle">// to be continued...</p>
          </div>
          <div class="mini-cover-divider"><span class="divider-accent"></span></div>
        </div>
        <div class="final-cta reveal">
          <div class="cta-asset-group">
            <picture>
              {/* mobile gets the tight sprint+flame crop so he reads BIG, no blueprint margins */}
              <source media="(max-width: 768px)" srcset="/she3bo/sheb3o-sprint-mobile.webp" width="720" height="430" />
              <img src="/she3bo/sheb3o-sprinting.webp" alt="Sheb3o sprinting forward in a trail of flame" class="cta-sheb3o" width="1024" height="574" loading="lazy" decoding="async" />
            </picture>
            <img src="/shata/shatta-wave.webp" alt="" aria-hidden="true" class="cta-shatta" width="116" height="230" loading="lazy" decoding="async" />
          </div>
          <div class="cta-content">
            <h2 class="cta-headline">READY TO TALK?</h2>
            <p class="cta-subtitle">// the protagonist's signoff</p>
            <a href="/contact" class="btn btn-primary btn-large">→ GET IN TOUCH</a>
          </div>
        </div>
      </section>

    </div>

    <!-- INK DOTS (margin doodles) -->
    <div class="ink-dots" aria-hidden="true">
      <span class="dot dot-1"></span>
      <span class="dot dot-2"></span>
      <span class="dot dot-3"></span>
    </div>

    <!-- MOBILE PROGRESS BAR -->
    <div class="mobile-progress" aria-hidden="true">
      <span class="progress-text">CHAPTER <span class="progress-current">I</span> OF VI</span>
    </div>

  </main>
</BaseLayout>

<style>
  .home-c2 {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 2rem;
    position: relative;
  }

  /* ─── SPINE ─── */
  .chapter-spine {
    position: sticky;
    top: 100px;
    align-self: start;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3.25rem;
    padding: 1rem 0;
    z-index: 3;
  }

  .spine-connector {
    position: absolute;
    left: 16px;
    top: calc(1rem + 16px);
    bottom: calc(1rem + 16px);
    width: 2.5px;
    background: var(--color-ink);
    opacity: 0.85;
    background-image: linear-gradient(
      to bottom,
      var(--color-ink) 0%,
      var(--color-ink) 95%,
      transparent 95%,
      transparent 100%
    );
    background-size: 100% 40px;
    z-index: 1;
  }

  .spine-marker {
    position: relative;
    display: flex;
    align-items: center;
    text-decoration: none;
    cursor: pointer;
    z-index: 2;
  }
  .marker-circle {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid var(--color-ink);
    background: var(--color-paper);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: all 250ms ease-out;
    flex-shrink: 0;
  }
  .marker-numeral {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: 0.02em;
    line-height: 1;
    transition: color 250ms ease-out;
  }
  .marker-tick {
    width: 16px;
    height: 2px;
    background: var(--color-ink);
    opacity: 0.6;
    margin-left: 4px;
    transition: all 250ms ease-out;
  }
  .marker-label {
    position: absolute;
    left: calc(100% + 12px);
    top: 50%;
    transform: translateY(-50%) translateX(-8px);
    white-space: nowrap;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    color: var(--color-ink);
    background: var(--color-paper);
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--color-ink);
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease-out, transform 200ms ease-out;
    z-index: 3;
  }

  .spine-marker:hover .marker-circle {
    border-width: 3px;
    transform: scale(1.1);
  }
  .spine-marker:hover .marker-tick {
    width: 24px;
    opacity: 1;
  }
  .spine-marker:hover .marker-label {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }

  .spine-marker[data-active="true"] .marker-circle {
    background: var(--color-shatta);
    border-color: var(--color-ink);
    transform: scale(1.2);
    box-shadow: 0 0 0 6px rgba(214, 40, 40, 0.12);
  }
  .spine-marker[data-active="true"] .marker-numeral {
    color: var(--color-paper);
  }
  .spine-marker[data-active="true"] .marker-tick {
    width: 32px;
    background: var(--color-shatta);
    opacity: 1;
    height: 2.5px;
  }
  .spine-marker[data-active="true"]:hover .marker-circle {
    background: var(--color-shatta);
    transform: scale(1.2);
  }

  .spine-marker[data-active="true"] .marker-circle::before,
  .spine-marker[data-active="true"] .marker-circle::after {
    content: '';
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-shatta);
  }
  .spine-marker[data-active="true"] .marker-circle::before {
    top: -8px;
    right: -10px;
    box-shadow: -4px 6px 0 0 var(--color-shatta), 8px 14px 0 0 var(--color-shatta);
  }
  .spine-marker[data-active="true"] .marker-circle::after {
    bottom: -10px;
    left: -8px;
    box-shadow: 12px -4px 0 0 var(--color-shatta);
  }

  .spine-shatta {
    position: absolute;
    left: 50%;
    top: 0;
    transform: translateX(-50%) translateY(-50%) rotate(0deg);
    width: 44px;
    height: auto;
    z-index: 4;
    pointer-events: none;
    will-change: top, transform;
    animation: shatta-bob 2.4s ease-in-out infinite;
  }
  .spine-shatta[data-sliding="true"] {
    animation: none;
  }
  @keyframes shatta-bob {
    0%, 100% { transform: translateX(-50%) translateY(-50%) rotate(var(--shatta-rotation, 0deg)); }
    50% { transform: translateX(-50%) translateY(calc(-50% - 4px)) rotate(var(--shatta-rotation, 0deg)); }
  }

  /* ─── CONTENT COLUMN ─── */
  .content-col {
    grid-column: 2;
    min-width: 0;
  }

  /* ─── BUTTONS ─── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    max-width: 100%;
    padding: 1rem 2rem;
    font-family: var(--font-display);
    font-size: 1.125rem;
    letter-spacing: 0.08em;
    text-decoration: none;
    border: 2px solid var(--color-ink);
    overflow-wrap: anywhere;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
    transition: transform 280ms var(--ease-hover), box-shadow 280ms var(--ease-hover);
  }
  .btn-primary { background: var(--color-ink); color: var(--color-paper); }
  .btn-secondary { background: var(--color-paper); color: var(--color-ink); }
  .btn:hover {
    transform: translate(-3px, -3px);
    box-shadow: 6px 6px 0 0 var(--color-shatta);
  }
  /* touch press (no hover on phones) */
  .btn:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 0 var(--color-shatta);
  }
  .btn-large { padding: 1.25rem 2.5rem; font-size: 1.5rem; }

  /* ─── CHAPTER SECTIONS ─── */
  .chapter-section {
    padding-block: clamp(4rem, 8vh, 7rem);
  }

  /* ─── MINI COVER ─── */
  .mini-cover {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
    position: relative;
  }
  .chapter-number {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    color: var(--color-shatta);
    font-weight: 700;
    min-width: 2rem;
  }
  .mini-cover-text { display: flex; flex-direction: column; gap: 0.25rem; }
  .mini-cover-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    color: var(--color-ink);
    margin: 0;
    letter-spacing: 0.04em;
  }
  .mini-cover-subtitle {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-ink-muted);
    font-style: italic;
    margin: 0;
  }
  .mini-cover-divider {
    flex: 1;
    height: 2px;
    background: var(--color-ink);
    position: relative;
    margin-left: 1rem;
  }
  .divider-accent {
    position: absolute;
    left: 0;
    top: -1px;
    width: 60px;
    max-width: 100%; /* clip to the (narrow) divider on mobile so it can't overflow 320px */
    height: 4px;
    background: var(--color-shatta);
  }

  /* ─── HERO ─── */
  .hero {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
    min-height: 75vh;
    position: relative;
  }

  /* manga cover corner stamp */
  .hero-stamp {
    position: absolute;
    top: clamp(0.5rem, 2vh, 1.5rem);
    right: 0;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    color: var(--color-ink-faded);
    writing-mode: vertical-rl;
    pointer-events: none;
    user-select: none;
  }

  /* current-arc status chip — the recruiter headline */
  .hero-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--color-ink);
    background: var(--color-paper-grain);
    border: var(--ink-thin) solid var(--color-ink);
    padding: 0.35rem 0.65rem;
    box-shadow: 2px 2px 0 0 var(--color-ink);
  }
  .hero-status__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-shatta);
    flex-shrink: 0;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 560px;
  }
  .hero-nickname {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin: 0;
    letter-spacing: 0.1em;
  }
  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(3rem, 9vw, 7rem);
    color: var(--color-ink);
    line-height: 0.9;
    margin: 0;
    letter-spacing: 0.02em;
    position: relative;
  }
  .name-underline {
    display: block;
    width: min(340px, 60%);
    height: 8px;
    margin-top: 10px;
  }

  /* underline draws itself in after the name lands (ink underline draw) */
  @media (prefers-reduced-motion: no-preference) {
    .name-underline__path {
      stroke-dasharray: 100;
      stroke-dashoffset: 100;
      animation: name-draw 500ms var(--ease-ink) 700ms forwards;
    }
  }
  @keyframes name-draw {
    to { stroke-dashoffset: 0; }
  }

  /* chili easter egg — flame-burst pop on hover (§14.1) */
  .chili {
    display: inline-block;
    cursor: default;
    transition: transform 280ms var(--ease-snap);
  }
  .chili:hover {
    transform: scale(1.35) rotate(-12deg);
  }
  .hero-tagline { display: flex; flex-direction: column; gap: 0.25rem; }
  .hero-tagline p {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-ink);
    margin: 0;
  }
  .tagline-spicy { color: var(--color-shatta) !important; font-style: italic; font-weight: 700; }
  .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
  .cv-link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    color: var(--color-ink-muted);
    text-decoration: none;
    margin-top: 0.25rem;
    width: fit-content;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.2s ease-out;
  }
  .cv-link:hover,
  .cv-link:active { color: var(--color-shatta); }
  .cv-arrow {
    display: inline-block;
    transition: transform 0.2s ease-out;
  }
  .cv-link:hover .cv-arrow { transform: rotate(45deg); }
  .hero-asset { display: flex; justify-content: center; align-items: center; position: relative; }
  .hero-asset img { max-width: 100%; max-height: 580px; object-fit: contain; position: relative; }

  /* manga speed-line burst radiating from behind the figure — fills the
     cover's dead middle and gives the hero its action-panel energy */
  .hero-burst {
    position: absolute;
    inset: -12% -18%;
    background: repeating-conic-gradient(
      from 0deg at 50% 42%,
      var(--color-ink) 0deg 0.55deg,
      transparent 0.55deg 6.5deg
    );
    opacity: 0.055;
    -webkit-mask-image: radial-gradient(ellipse 50% 46% at 50% 42%, transparent 34%, var(--color-ink) 52%, transparent 78%);
    mask-image: radial-gradient(ellipse 50% 46% at 50% 42%, transparent 34%, var(--color-ink) 52%, transparent 78%);
    pointer-events: none;
  }

  /* Sheb3o breath — approved hero idle (§8.2, 4s ease-in-out loop).
     The container handles the entrance rise; the img only breathes. */
  @media (prefers-reduced-motion: no-preference) {
    .hero-asset img {
      animation: hero-breath 4s ease-in-out 1.2s infinite;
    }
  }
  @keyframes hero-breath {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  /* scroll cue — quiet pointer to the story below the fold */
  .hero-scrollcue {
    position: absolute;
    left: 50%;
    bottom: 0.25rem;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-faded);
    pointer-events: none;
    user-select: none;
  }

  /* ── HERO ENTRANCE — load choreography (above-fold, so not scroll-driven).
        Each element gets its full animation incl. delay so cascade order can't
        reset the stagger. `backwards` holds the start state during the delay. ── */
  @media (prefers-reduced-motion: no-preference) {
    .hero-status   { animation: hero-rise 600ms var(--ease-ink)  40ms backwards; }
    .hero-nickname { animation: hero-rise 600ms var(--ease-ink) 100ms backwards; }
    .hero-name     { animation: hero-rise 600ms var(--ease-ink) 180ms backwards; }
    .hero-tagline  { animation: hero-rise 600ms var(--ease-ink) 280ms backwards; }
    .hero-ctas     { animation: hero-rise 600ms var(--ease-ink) 380ms backwards; }
    .cv-link       { animation: hero-rise 600ms var(--ease-ink) 460ms backwards; }
    /* transform-only for the hero art: an opacity ramp on the LCP image delays
       the LCP paint until the fade ends (~1s, 4-5s under mobile CPU throttle) */
    .hero-asset    { animation: hero-rise-img 720ms var(--ease-ink) 220ms backwards; }
    /* quiet furniture fades in after the headline settles */
    .hero-stamp,
    .hero-scrollcue { animation: hero-fade 600ms var(--ease-ink) 900ms backwards; }
  }
  @keyframes hero-fade {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-rise-img {
    from { transform: translateY(22px); }
    to   { transform: translateY(0); }
  }

  /* ─── STATS ─── */
  .stats-strip {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3rem;
    align-items: center;
    position: relative;
  }
  .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  /* inked stat blocks — the manga "character sheet" read */
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.25rem 1rem;
    border: var(--ink-medium) solid var(--color-ink);
    background: var(--color-paper);
    box-shadow: var(--ink-shadow-sm);
    transition: transform 280ms var(--ease-hover), box-shadow 280ms var(--ease-hover);
  }
  .stat:hover {
    transform: translate(-2px, -2px);
    box-shadow: var(--ink-shadow);
  }
  /* .reveal's global transition/transform rules outrank the card's own —
     restate hover + fast transition at higher specificity once revealed */
  html.js .stat.reveal.is-in {
    transition: transform 280ms var(--ease-hover), box-shadow 280ms var(--ease-hover), opacity 600ms var(--ease-ink);
  }
  html.js .stat.reveal.is-in:hover {
    transform: translate(-2px, -2px);
    box-shadow: var(--ink-shadow);
  }
  .stat-number {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    color: var(--color-shatta);
    line-height: 1;
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-ink-muted);
    line-height: 1.4;
  }
  /* paper backdrop so the flex art's ink-on-white sketch multiplies into
     the page instead of showing its white box */
  .stats-asset {
    position: relative;
    background: var(--color-paper);
    display: flex;
    justify-content: center;
    align-items: flex-end;
  }
  .stats-asset picture { display: contents; }
  .stats-asset img { max-width: 100%; max-height: 420px; object-fit: contain; mix-blend-mode: multiply; }
  /* Shatta flexing in solidarity — knee-height, at Sheb3o's feet */
  .stats-shatta {
    position: absolute;
    bottom: 0;
    left: 4%;
    height: 95px;
    width: auto;
    max-height: 95px;
    object-fit: contain;
    transform: rotate(8deg);
    z-index: 1;
  }

  /* ─── FEATURED ─── */
  .featured-card {
    width: 100%;
    background: var(--color-paper);
    border: 3px solid var(--color-ink);
    padding: 3rem;
    box-shadow: 8px 8px 0 0 var(--color-shatta);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
  }
  .featured-shatta {
    position: absolute;
    top: -28px;
    right: -10px;
    height: 75px;
    object-fit: contain;
    z-index: 3;
    transform: rotate(8deg);
  }
  .corner-bracket { position: absolute; opacity: 0.5; }
  .corner-tl { top: -8px; left: -8px; }
  .corner-tr { top: -8px; right: -8px; }
  .corner-bl { bottom: -8px; left: -8px; }
  .corner-br { bottom: -8px; right: -8px; }
  .featured-header { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .featured-name {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5rem);
    color: var(--color-ink);
    line-height: 0.9;
    margin: 0;
  }
  .status-pill {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .status-live { background: var(--color-shatta); color: var(--color-paper); }
  .status-forged { border: 1px solid var(--color-ink); color: var(--color-ink); background: transparent; }
  .status-current { background: var(--color-shatta); color: var(--color-paper); }
  .featured-tagline {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-ink-muted);
    line-height: 1.6;
    margin: 0;
  }
  .tech-chips { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .chip {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-ink);
    color: var(--color-ink);
    border-radius: 0;
    transition: transform 280ms var(--ease-hover), box-shadow 280ms var(--ease-hover);
  }
  .chip:hover {
    transform: translateY(-2px);
    box-shadow: 3px 3px 0 0 var(--color-shatta);
  }

  /* ─── PROJECT CAROUSEL (auto-rotating, swipeable, no-JS-safe) ─── */
  .pcarousel {
    position: relative;
    border: var(--ink-thick) solid var(--color-ink);
    border-radius: 2px;
    box-shadow: 8px 8px 0 0 var(--color-shatta);
    background: var(--color-paper);
    margin-top: 0.5rem;
  }
  .pcarousel::before,
  .pcarousel::after {
    content: '';
    position: absolute;
    width: 22px;
    height: 22px;
    pointer-events: none;
  }
  .pcarousel::before { top: -7px; left: -7px; border-top: var(--ink-thick) solid var(--color-ink); border-left: var(--ink-thick) solid var(--color-ink); }
  .pcarousel::after { bottom: -7px; right: -7px; border-bottom: var(--ink-thick) solid var(--color-ink); border-right: var(--ink-thick) solid var(--color-ink); }
  .pcarousel__shatta {
    position: absolute;
    top: -28px;
    right: -6px;
    height: 62px;
    width: auto;
    object-fit: contain;
    transform: rotate(8deg);
    z-index: 3;
    pointer-events: none;
  }
  .pcarousel__viewport {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .pcarousel__viewport::-webkit-scrollbar { display: none; }

  .pcard {
    flex: 0 0 100%;
    min-width: 0;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: clamp(1.5rem, 5vw, 3rem);
  }
  .pcard__top { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .pcard__num { font-family: var(--font-mono); font-size: 0.8125rem; font-weight: 700; letter-spacing: 0.14em; color: var(--color-shatta); }
  .pcard__name { font-family: var(--font-display); font-size: clamp(2.5rem, 7vw, 5rem); color: var(--color-ink); line-height: 0.9; margin: 0; overflow-wrap: anywhere; }
  .pcard__tagline { font-family: var(--font-body); font-size: 1.05rem; color: var(--color-ink-muted); line-height: 1.6; margin: 0; max-width: 52ch; }
  .pcard__cta { align-self: flex-start; margin-top: auto; }

  .pcarousel__dots { display: flex; justify-content: center; gap: 0.3rem; margin-top: 1.4rem; flex-wrap: wrap; }
  .pdot {
    width: 34px; height: 34px;
    display: grid; place-items: center;
    background: none; border: none; cursor: pointer; padding: 0; min-height: 0;
    -webkit-tap-highlight-color: transparent;
  }
  .pdot::before {
    content: '';
    width: 11px; height: 11px;
    border: var(--ink-medium) solid var(--color-ink);
    background: transparent;
    transition: background-color 280ms var(--ease-hover), transform 280ms var(--ease-hover);
  }
  .pdot.is-active::before { background: var(--color-shatta); border-color: var(--color-shatta); transform: scale(1.25); }
  .pdot:hover::before { border-color: var(--color-shatta); }

  @media (prefers-reduced-motion: reduce) {
    .pcarousel__viewport { scroll-behavior: auto; }
  }

  /* ─── CTA LINKS (unified) ─── */
  .cta-link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-ink);
    text-decoration: none;
    width: fit-content;
    max-width: 100%;
    padding: 0.5rem 0;
    border-bottom: 2px solid var(--color-shatta);
    -webkit-tap-highlight-color: transparent;
    transition: color 0.2s ease-out, transform 0.2s ease-out;
  }
  .cta-link:hover,
  .cta-link:active {
    color: var(--color-shatta);
    transform: translateX(4px);
  }
  .see-all { margin-top: 1.5rem; }

  /* ─── COMIC TRANSITIONS ─── */
  .comic-transition {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0;
  }
  .transition-line {
    flex: 1;
    height: 1px;
    background: var(--color-ink-muted);
    opacity: 0.4;
  }
  .transition-text {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    white-space: nowrap;
    position: relative;
  }
  .transition-next::before,
  .transition-next::after {
    content: '';
    position: absolute;
    width: 1px;
    height: 12px;
    background: var(--color-ink);
    opacity: 0.4;
    top: 50%;
    transform: translateY(-50%);
  }
  .transition-next::before { left: -0.75rem; }
  .transition-next::after { right: -0.75rem; }
  .transition-meanwhile {
    font-style: italic;
    display: inline-block;
    padding: 0.5rem 1rem;
    border-top: 1px solid var(--color-ink-muted);
    border-bottom: 1px solid var(--color-ink-muted);
    background: var(--color-paper-shadow);
  }

  /* ─── ABOUT ─── */
  .about-layout {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: center;
  }
  .about-asset img { max-width: 100%; max-height: 500px; object-fit: contain; }
  .about-content { display: flex; flex-direction: column; gap: 1.5rem; }
  .about-hook {
    font-family: var(--font-body);
    font-size: 1.25rem;
    color: var(--color-ink);
    line-height: 1.6;
    margin: 0;
  }

  /* ─── TECHNIQUES (POWER BARS) ─── */
  .techniques-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .technique-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border: 2px solid var(--color-ink);
    background: var(--color-paper);
  }
  .tech-name {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-ink);
    min-width: 90px;
    letter-spacing: 0.02em;
  }
  .power-bar-track {
    flex: 1;
    height: 18px;
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper);
    overflow: hidden;
  }
  .power-bar-fill {
    height: 100%;
    transform-origin: left center;
    background-image: repeating-linear-gradient(
      -45deg,
      var(--color-shatta),
      var(--color-shatta) 6px,
      color-mix(in srgb, var(--color-shatta) 85%, transparent) 6px,
      color-mix(in srgb, var(--color-shatta) 85%, transparent) 7px
    );
  }
  /* power bars "charge up" on scroll-in (scaleX — never width) */
  html.js .technique-row.reveal .power-bar-fill {
    transform: scaleX(0);
    transition: transform 700ms var(--ease-ink);
  }
  html.js .technique-row.reveal.is-in .power-bar-fill {
    transform: scaleX(1);
  }

  /* ─── ARCS ─── */
  .arcs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .arc {
    padding: 2rem;
    border: 2px solid var(--color-ink);
    background: var(--color-paper);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
  }
  .arc-current { box-shadow: 4px 4px 0 0 var(--color-shatta); }
  .arc-num {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-shatta);
    font-weight: 700;
    letter-spacing: 0.1em;
  }
  .arc-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-ink);
    margin: 0;
  }
  .arc-summary {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-ink-muted);
    line-height: 1.5;
    margin: 0;
  }
  .arc-shatta-flag {
    position: absolute;
    top: -25px;
    right: 10px;
    height: 50px;
    object-fit: contain;
    transform: rotate(8deg);
  }

  /* ─── FINAL CTA ─── */
  .final-cta {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: center;
  }
  .cta-asset-group {
    display: flex;
    align-items: flex-end;
    position: relative;
    min-width: 0;
    /* paper backdrop inside this stacking context so the sprint art's
       ink-on-white sketch can multiply into the page instead of boxing */
    background: var(--color-paper);
  }
  /* let the <picture> wrapper collapse so the img is the flex child */
  .cta-asset-group picture { display: contents; }
  .cta-sheb3o {
    max-width: 100%;
    max-height: 320px;
    width: auto;
    height: auto;
    object-fit: contain;
    mix-blend-mode: multiply;
  }
  /* Shatta cheering at the end of the flame trail — anchored to the art,
     never spilling into the content column */
  .cta-shatta {
    position: absolute;
    right: -4px;
    bottom: 4px;
    max-height: 96px;
    width: auto;
    object-fit: contain;
    transform: rotate(-5deg);
  }
  .cta-content { display: flex; flex-direction: column; gap: 1rem; align-items: flex-start; }
  .cta-headline {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5rem);
    color: var(--color-ink);
    line-height: 0.9;
    margin: 0;
  }
  .cta-subtitle {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-ink-muted);
    font-style: italic;
    margin: 0 0 1rem;
  }

  /* ─── INK DOTS ─── */
  .ink-dots {
    position: fixed;
    top: 0;
    right: 0;
    width: 40px;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
  .dot {
    position: absolute;
    background: var(--color-ink);
    border-radius: 50%;
    opacity: 0.15;
  }
  .dot-1 { width: 5px; height: 5px; top: 25%; right: 12px; }
  .dot-2 { width: 4px; height: 4px; top: 60%; right: 20px; }
  .dot-3 { width: 6px; height: 6px; top: 85%; right: 8px; }

  /* ─── MOBILE PROGRESS BAR ─── */
  .mobile-progress {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--color-ink);
    color: var(--color-paper);
    text-align: center;
    padding: 0.5rem 0.5rem calc(0.5rem + env(safe-area-inset-bottom));
    z-index: 10;
  }
  .progress-text {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .progress-current {
    color: var(--color-shatta);
    font-weight: 700;
  }

  /* ─── MOBILE ─── */
  @media (max-width: 768px) {
    .home-c2 {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .chapter-spine { display: none; }
    .content-col { grid-column: 1; }
    .mobile-progress { display: block; }
    .ink-dots { display: none; }
    .hero {
      grid-template-columns: 1fr;
      gap: 2rem;
      min-height: auto;
    }
    .hero { position: static; }
    .hero-section { position: relative; }   /* figure spans the WHOLE hero section */
    /* cover furniture is desktop-only — the mobile hero is the tight cutout */
    .hero-stamp, .hero-scrollcue, .hero-burst { display: none; }
    /* text stays on the left + always above the figure */
    .hero-content { max-width: none; position: relative; z-index: 1; }
    .hero-status {
      max-width: 100%;
      font-size: 0.6875rem;
      align-items: flex-start;
      line-height: 1.5;
    }
    .hero-status__dot { margin-top: 0.3rem; }
    .hero-tagline { max-width: 50%; }
    .hero-ctas { max-width: 50%; flex-direction: column; align-items: stretch; gap: 0.6rem; }
    .cv-link { max-width: 50%; }
    /* compact hero buttons so labels stay on ONE line in the narrow column
       (overrides the global .btn padding/letter-spacing/overflow-wrap) */
    .hero-ctas .btn {
      padding: 0.7rem 0.75rem;
      font-size: clamp(0.8rem, 3.2vw, 1.05rem);
      letter-spacing: 0.04em;
      white-space: nowrap;
      overflow-wrap: normal;
      min-height: 46px;
    }
    /* Sheb3o — BIG tight-cropped cutout filling the right column, NO box */
    .hero-asset {
      position: absolute;
      top: clamp(4rem, 12vh, 5.5rem);
      right: -0.5rem;
      bottom: clamp(0.5rem, 2vh, 1.25rem);
      width: 54%;
      margin: 0;
      padding: 0;
      border: none;
      background: none;
      box-shadow: none;
      overflow: visible;
      pointer-events: none;
      z-index: 0;
    }
    .hero-asset::before,
    .hero-asset::after { content: none; }
    .hero-asset img {
      width: 100%;
      height: 100%;
      max-height: none;
      object-fit: contain;
      object-position: bottom center;
    }
    /* THE STATS — mirror the hero: numbers left, BIG flex-Sheb3o right, no box */
    #ch-2 { position: relative; }
    .stats-strip { position: static; grid-template-columns: 1fr; gap: 0; }
    .stats-grid { position: relative; z-index: 1; grid-template-columns: 1fr; gap: 1.25rem; max-width: 52%; }
    .stat-number { font-size: clamp(2rem, 9.5vw, 3rem); }
    .stats-asset {
      position: absolute;
      top: clamp(4rem, 10vh, 5.5rem);
      right: -0.5rem;
      bottom: clamp(1rem, 3vh, 2rem);
      width: 54%;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      margin: 0;
      pointer-events: none;
      z-index: 0;
    }
    /* only the flex art fills the overlay — never the Shatta doodle */
    .stats-asset picture img {
      width: 100%;
      height: 100%;
      max-height: none;
      object-fit: contain;
      object-position: bottom center;
    }
    /* Shatta flexing in solidarity — knee-height, lower-left (DESIGN.md §13) */
    .stats-shatta {
      position: absolute;
      bottom: clamp(0.5rem, 3vh, 1.5rem);
      left: 0;
      height: 72px;
      width: auto;
      max-height: 72px;
      margin: 0;
      transform: rotate(8deg);
      z-index: 1;
    }
    .about-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .about-asset img { max-height: 280px; }
    .techniques-grid { grid-template-columns: 1fr; }
    .tech-name { min-width: 100px; }
    .arcs-grid { grid-template-columns: 1fr; }
    /* FINALE — big dynamic sprint across the top, centered signoff below */
    .final-cta {
      grid-template-columns: 1fr;
      gap: 1.25rem;
      text-align: center;
    }
    .cta-asset-group {
      position: relative;
      max-width: 100%;
      justify-content: center;
      align-items: flex-end;
      gap: 0;
    }
    .cta-sheb3o { width: 100%; max-width: 440px; max-height: none; height: auto; }
    /* Shatta cheering at the end of the flame trail */
    .cta-shatta {
      position: absolute;
      right: 2%;
      bottom: 8%;
      max-height: 64px;
      max-width: 22%;
      height: auto;
      margin: 0;
    }
    .cta-content { width: 100%; align-items: center; }
    .cta-subtitle { margin-bottom: 0.5rem; }
    .cta-content .btn-large { width: 100%; font-size: 1.25rem; padding: 1.05rem 1.25rem; }
    /* keep content clear of the fixed chapter bar */
    .content-col { padding-bottom: calc(2.75rem + env(safe-area-inset-bottom)); }
    .featured-card { padding: 1.5rem; }
    .featured-shatta { height: 50px; top: -20px; right: 5px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .spine-shatta { animation: none !important; }
    .spine-marker, .marker-circle, .marker-tick, .marker-label {
      transition: none !important;
    }
  }
</style>

<script>
  (function() {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobileQuery = window.matchMedia('(max-width: 768px)');

    if (isMobileQuery.matches) return;

    const shatta = document.querySelector('.spine-shatta') as HTMLElement | null;
    const markers = document.querySelectorAll('.spine-marker');
    const sections = document.querySelectorAll('[data-chapter]');
    const spine = document.querySelector('.chapter-spine') as HTMLElement | null;
    const progressCurrent = document.querySelector('.progress-current');
    const chapterNumerals = ['I', 'II', 'III', 'IV', 'V', 'VI'];

    if (!shatta || !markers.length || !sections.length || !spine) return;

    let lastTopPosition = 0;
    let slideTimeout: ReturnType<typeof setTimeout> | null = null;

    function getMarkerCenter(marker: Element): number {
      const spineRect = spine!.getBoundingClientRect();
      const markerRect = marker.getBoundingClientRect();
      return (markerRect.top - spineRect.top) + (markerRect.height / 2);
    }

    function slideShattaTo(markerId: string, isLast = false) {
      const marker = document.querySelector(`[data-target="${markerId}"]`);
      if (!marker || !shatta) return;

      let targetTop = getMarkerCenter(marker);

      if (isLast) {
        targetTop += 22;
      }

      const isMovingDown = targetTop > lastTopPosition;
      const rotation = reducedMotion ? 0 : (isLast ? 5 : (isMovingDown ? -8 : 8));

      shatta.setAttribute('data-sliding', 'true');

      if (reducedMotion) {
        shatta.style.transition = 'none';
      } else {
        shatta.style.transition = 'top 450ms cubic-bezier(0.34, 1.2, 0.64, 1), transform 450ms ease-out';
      }

      shatta.style.setProperty('--shatta-rotation', rotation + 'deg');
      shatta.style.transform = `translateX(-50%) translateY(-50%) rotate(${rotation}deg)`;
      shatta.style.top = targetTop + 'px';

      lastTopPosition = targetTop;

      markers.forEach(m => m.removeAttribute('data-active'));
      marker.setAttribute('data-active', 'true');

      if (slideTimeout) clearTimeout(slideTimeout);
      slideTimeout = setTimeout(() => {
        shatta.removeAttribute('data-sliding');
        const restRotation = isLast ? 5 : 0;
        shatta.style.setProperty('--shatta-rotation', restRotation + 'deg');
      }, 460);
    }

    function updateMobileProgress(index: number) {
      if (progressCurrent) {
        progressCurrent.textContent = chapterNumerals[index] || 'I';
      }
    }

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const sectionId = el.id;
            const allSections = Array.from(sections);
            const idx = allSections.indexOf(el);
            const isLast = el === allSections[allSections.length - 1];
            slideShattaTo(sectionId, isLast);
            updateMobileProgress(Math.max(0, idx));
          }
        });
      }, {
        rootMargin: '-25% 0px -55% 0px',
        threshold: 0,
      });

      sections.forEach(section => observer.observe(section));
    }

    markers.forEach(marker => {
      marker.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = (marker as HTMLElement).getAttribute('data-target');
        if (!targetId) return;
        const target = document.getElementById(targetId);
        if (target) {
          target.scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'start' });
        }
      });
    });

    function initShatta() {
      const firstMarker = markers[0];
      if (firstMarker && shatta) {
        const top = getMarkerCenter(firstMarker);
        shatta.style.transition = 'none';
        shatta.style.top = top + 'px';
        lastTopPosition = top;
        firstMarker.setAttribute('data-active', 'true');
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => setTimeout(initShatta, 100));
    } else {
      setTimeout(initShatta, 100);
    }

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        if (window.matchMedia('(max-width: 768px)').matches) return;
        const activeMarker = document.querySelector('.spine-marker[data-active="true"]');
        if (activeMarker) {
          const sectionId = activeMarker.getAttribute('data-target');
          if (sectionId) {
            const sec = document.getElementById(sectionId);
            const allSections = Array.from(sections);
            slideShattaTo(sectionId, sec === allSections[allSections.length - 1]);
          }
        }
      }, 200);
    });
  })();
</script>

<script>
  // Auto-rotating project carousel. No-JS: it's a swipeable scroll-snap row.
  // JS adds auto-advance (paused on interaction, off under reduced-motion) + dots.
  function initProjectCarousel() {
    const root = document.querySelector('[data-carousel]') as HTMLElement | null;
    if (!root || root.dataset.cwired) return;
    const track = root.querySelector('[data-carousel-track]') as HTMLElement | null;
    const slides = Array.from(root.querySelectorAll('[data-carousel-slide]'));
    const dots = Array.from(document.querySelectorAll('[data-carousel-dot]')) as HTMLElement[];
    if (!track || slides.length < 2) return;
    root.dataset.cwired = '1';

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
    let index = 0;
    let timer: ReturnType<typeof setInterval> | null = null;

    function setActive(i: number) {
      dots.forEach((d, di) => {
        const on = di === i;
        d.classList.toggle('is-active', on);
        d.setAttribute('aria-selected', on ? 'true' : 'false');
      });
    }
    function go(i: number, smooth: boolean) {
      index = (i + slides.length) % slides.length;
      track!.scrollTo({ left: index * track!.clientWidth, behavior: smooth && !reduce.matches ? 'smooth' : 'auto' });
      setActive(index);
    }
    function start() {
      if (reduce.matches || timer) return;
      timer = setInterval(() => go(index + 1, true), 4500);
    }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }

    dots.forEach((d, di) => d.addEventListener('click', () => { go(di, true); stop(); start(); }));

    let st: ReturnType<typeof setTimeout>;
    track.addEventListener('scroll', () => {
      clearTimeout(st);
      st = setTimeout(() => {
        const i = Math.round(track.scrollLeft / track.clientWidth);
        if (i !== index) { index = i; setActive(i); }
      }, 120);
    }, { passive: true });

    ['pointerenter', 'focusin', 'touchstart'].forEach((e) => root.addEventListener(e, stop, { passive: true }));
    ['pointerleave', 'focusout', 'touchend'].forEach((e) => root.addEventListener(e, () => setTimeout(start, 800), { passive: true }));
    document.addEventListener('visibilitychange', () => { if (document.hidden) stop(); else start(); });
    reduce.addEventListener('change', () => { stop(); if (!reduce.matches) start(); });
    window.addEventListener('resize', () => go(index, false));

    setActive(0);
    start();
  }
  document.addEventListener('astro:page-load', initProjectCarousel);
</script>
