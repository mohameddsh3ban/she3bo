  }
  .cta-content { display: flex; flex-direction: column; gap: 1rem; align-items: flex-start; }
  .cta-headline {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5rem);
    color: var(--color-ink);
    line-height: 0.9;
