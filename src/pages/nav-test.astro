---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavTopBar from '@components/nav/NavTopBar.astro';
import NavSideRail from '@components/nav/NavSideRail.astro';
import NavFloatingButtons from '@components/nav/NavFloatingButtons.astro';
---

<BaseLayout
  title="Navigation Variants — she3bo.com V2"
  description="Compare three navigation variants for the she3bo portfolio."
>
  <div class="navtest">
    <a href="/" class="navtest__back">← Home</a>
    <h1 class="navtest__title">NAVIGATION VARIANTS</h1>
    <p class="navtest__intro">Three navigation approaches for she3bo.com V2. Compare side-by-side.</p>

    {/* ─── VARIANT A ──────────────────────────────────────────── */}
    <section class="navtest__section">
      <h2 class="navtest__label">VARIANT A: TOP BAR</h2>
      <div class="navtest__viewport navtest__viewport--a">
        <NavTopBar activeLink="#experience" />
        <div class="navtest__filler">
          <p class="font-mono">Scroll area — sticky bar stays pinned to top</p>
        </div>
      </div>
      <div class="navtest__notes">
        <p><strong>Best for:</strong> Familiar pattern, zero learning curve. Recruiters find links instantly. Mobile hamburger works everywhere.</p>
        <p><strong>Concerns:</strong> Takes vertical space on every page. Less visually unique — looks like most portfolio navs.</p>
      </div>
    </section>

    {/* ─── VARIANT B ──────────────────────────────────────────── */}
    <section class="navtest__section">
      <h2 class="navtest__label">VARIANT B: SIDE RAIL</h2>
      <div class="navtest__viewport navtest__viewport--b">
        <NavSideRail activeLink="#skills" />
        <div class="navtest__filler navtest__filler--b">
          <p class="font-mono">Main content area — side rail stays fixed on left (desktop only)</p>
        </div>
      </div>
      <div class="navtest__notes">
        <p><strong>Best for:</strong> Manga panel aesthetic. Single-letter abbreviations feel like manga chapter tabs. Saves vertical space.</p>
        <p><strong>Concerns:</strong> 80px eaten from content width on desktop. Letter abbreviations less discoverable — hover required to see full name.</p>
      </div>
    </section>

    {/* ─── VARIANT C ──────────────────────────────────────────── */}
    <section class="navtest__section">
      <h2 class="navtest__label">VARIANT C: FLOATING BUTTONS</h2>
      <div class="navtest__viewport navtest__viewport--c">
        <NavFloatingButtons activeLink="#projects" />
        <div class="navtest__filler">
          <p class="font-mono">Full-bleed content area — floating pills overlay top-right corner</p>
        </div>
      </div>
      <div class="navtest__notes">
        <p><strong>Best for:</strong> Maximum content space. Ink-button style matches manga sketch aesthetic. Chili icon on mobile is on-brand.</p>
        <p><strong>Concerns:</strong> Overlaps content in top-right corner. Pill group may wrap on narrow desktop. Less conventional for recruiters.</p>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .navtest {
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--spacing-md);
  }

  .navtest__back {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-ink);
    text-decoration: none;
    display: inline-block;
    margin-bottom: var(--spacing-md);
    border-bottom: var(--ink-thin) solid var(--color-ink);
    padding-bottom: 2px;
  }

  .navtest__back:hover {
    color: var(--color-shatta);
    border-bottom-color: var(--color-shatta);
  }

  .navtest__title {
    font-size: clamp(2rem, 5vw, 4rem);
    margin-bottom: var(--spacing-xs);
  }

  .navtest__intro {
    font-family: var(--font-body);
    color: var(--color-ink-muted);
    margin-bottom: var(--spacing-lg);
  }

  .navtest__section {
    margin-bottom: var(--spacing-xl);
  }

  .navtest__label {
    font-size: clamp(1.25rem, 3vw, 2rem);
    color: var(--color-ink);
    margin-bottom: var(--spacing-sm);
    padding-bottom: var(--spacing-xs);
    border-bottom: var(--ink-thick) solid var(--color-ink);
    display: inline-block;
  }

  /* Viewport containers to demo each nav in isolation */
  .navtest__viewport {
    position: relative;
    overflow: hidden;
    border: var(--ink-bold) solid var(--color-ink);
    background-color: var(--color-paper-grain);
    border-radius: 2px;
  }

  .navtest__viewport--a {
    height: 250px;
    overflow-y: auto;
  }

  .navtest__viewport--b {
    height: 500px;
    overflow-y: auto;
  }

  .navtest__viewport--c {
    height: 250px;
    overflow-y: auto;
  }

  .navtest__filler {
    padding: var(--spacing-lg) var(--spacing-md);
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .navtest__filler--b {
    padding-left: 100px;
  }

  @media (max-width: 767px) {
    .navtest__filler--b {
      padding-left: var(--spacing-md);
    }
  }

  .navtest__filler p {
    color: var(--color-ink-faded);
    text-align: center;
    font-size: 0.875rem;
  }

  .navtest__notes {
    margin-top: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
    background-color: var(--color-paper-shadow);
    border: var(--ink-medium) solid var(--color-ink);
    border-radius: 2px;
  }

  .navtest__notes p {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    margin-bottom: var(--spacing-xs);
  }

  .navtest__notes p:last-child {
    margin-bottom: 0;
  }

  .navtest__notes strong {
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
